8143:Core/Src/bmi270/bmi2.c **** /*!
8144:Core/Src/bmi270/bmi2.c ****  * @brief This internal API is used to parse the auxiliary data from the
8145:Core/Src/bmi270/bmi2.c ****  * FIFO in headerless mode.
8146:Core/Src/bmi270/bmi2.c ****  */
