9648:Core/Src/bmi270/bmi2.c **** /*!
9649:Core/Src/bmi270/bmi2.c ****  * @brief This internal API scales the compensated accelerometer data according
9650:Core/Src/bmi270/bmi2.c ****  * to the offset register resolution.
9651:Core/Src/bmi270/bmi2.c ****  *
9652:Core/Src/bmi270/bmi2.c ****  * @note The bit position is always greater than 0 since accelerometer data is
9653:Core/Src/bmi270/bmi2.c ****  * 16 bit wide.
9654:Core/Src/bmi270/bmi2.c ****  */
9655:Core/Src/bmi270/bmi2.c **** static void scale_accel_offset(uint8_t range, const struct bmi2_offset_delta *comp_data, struct bmi
9656:Core/Src/bmi270/bmi2.c **** {
9657:Core/Src/bmi270/bmi2.c ****     /* Variable to store the position of bit having 3.9mg resolution */
9658:Core/Src/bmi270/bmi2.c ****     int8_t bit_pos_3_9mg;
9659:Core/Src/bmi270/bmi2.c **** 
9660:Core/Src/bmi270/bmi2.c ****     /* Variable to store the position previous of bit having 3.9mg resolution */
9661:Core/Src/bmi270/bmi2.c ****     int8_t bit_pos_3_9mg_prev_bit;
9662:Core/Src/bmi270/bmi2.c **** 
9663:Core/Src/bmi270/bmi2.c ****     /* Variable to store the round-off value */
9664:Core/Src/bmi270/bmi2.c ****     uint8_t round_off;
9665:Core/Src/bmi270/bmi2.c **** 
9666:Core/Src/bmi270/bmi2.c ****     /* Find the bit position of 3.9mg */
9667:Core/Src/bmi270/bmi2.c ****     bit_pos_3_9mg = get_bit_pos_3_9mg(range);
9668:Core/Src/bmi270/bmi2.c **** 
9669:Core/Src/bmi270/bmi2.c ****     /* Round off, consider if the next bit is high */
9670:Core/Src/bmi270/bmi2.c ****     bit_pos_3_9mg_prev_bit = bit_pos_3_9mg - 1;
9671:Core/Src/bmi270/bmi2.c ****     round_off = (uint8_t)(power(2, ((uint8_t) bit_pos_3_9mg_prev_bit)));
9672:Core/Src/bmi270/bmi2.c **** 
9673:Core/Src/bmi270/bmi2.c ****     /* Scale according to offset register resolution */
9674:Core/Src/bmi270/bmi2.c ****     data->x = (uint8_t)((comp_data->x + round_off) / power(2, ((uint8_t) bit_pos_3_9mg)));
9675:Core/Src/bmi270/bmi2.c ****     data->y = (uint8_t)((comp_data->y + round_off) / power(2, ((uint8_t) bit_pos_3_9mg)));
9676:Core/Src/bmi270/bmi2.c ****     data->z = (uint8_t)((comp_data->z + round_off) / power(2, ((uint8_t) bit_pos_3_9mg)));
9677:Core/Src/bmi270/bmi2.c **** }
