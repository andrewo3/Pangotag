8175:Core/Src/bmi270/bmi2.c ****     {
8176:Core/Src/bmi270/bmi2.c ****         rslt = check_dummy_frame(BMI2_FIFO_HEADERLESS_DUMMY_AUX, &data_index, skip_length, fifo);
8177:Core/Src/bmi270/bmi2.c **** 
8178:Core/Src/bmi270/bmi2.c ****         /* Unpack only if Valid frame is present */
8179:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
8180:Core/Src/bmi270/bmi2.c ****         {
8181:Core/Src/bmi270/bmi2.c ****             /* Unpack frame to get auxiliary data */
8182:Core/Src/bmi270/bmi2.c ****             rslt = unpack_aux_frame(aux, &data_index, &aux_index, data_enable, fifo, dev);
8183:Core/Src/bmi270/bmi2.c **** 
