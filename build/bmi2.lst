2219:Core/Src/bmi270/bmi2.c **** /*!
2220:Core/Src/bmi270/bmi2.c ****  * @brief This API loads the configuration file into the bmi2 sensor.
2221:Core/Src/bmi270/bmi2.c ****  */
2222:Core/Src/bmi270/bmi2.c **** int8_t bmi2_write_config_file(struct bmi2_dev *dev)
2223:Core/Src/bmi270/bmi2.c **** {
2224:Core/Src/bmi270/bmi2.c ****     /* Variable to define error */
2225:Core/Src/bmi270/bmi2.c ****     int8_t rslt;
2226:Core/Src/bmi270/bmi2.c **** 
2227:Core/Src/bmi270/bmi2.c ****     /* Variable to know the load status */
2228:Core/Src/bmi270/bmi2.c ****     uint8_t load_status = 0;
2229:Core/Src/bmi270/bmi2.c **** 
2230:Core/Src/bmi270/bmi2.c ****     /* Null-pointer check */
2231:Core/Src/bmi270/bmi2.c ****     rslt = null_ptr_check(dev);
2232:Core/Src/bmi270/bmi2.c ****     if ((rslt == BMI2_OK) && (dev->config_size != 0))
2233:Core/Src/bmi270/bmi2.c ****     {
2234:Core/Src/bmi270/bmi2.c ****         /* Bytes written are multiples of 2 */
2235:Core/Src/bmi270/bmi2.c ****         if ((dev->read_write_len % 2) != 0)
2236:Core/Src/bmi270/bmi2.c ****         {
2237:Core/Src/bmi270/bmi2.c ****             dev->read_write_len = dev->read_write_len - 1;
2238:Core/Src/bmi270/bmi2.c ****         }
2239:Core/Src/bmi270/bmi2.c **** 
2240:Core/Src/bmi270/bmi2.c ****         if (dev->read_write_len < 2)
2241:Core/Src/bmi270/bmi2.c ****         {
2242:Core/Src/bmi270/bmi2.c ****             dev->read_write_len = 2;
2243:Core/Src/bmi270/bmi2.c ****         }
2244:Core/Src/bmi270/bmi2.c **** 
2245:Core/Src/bmi270/bmi2.c ****         /* Write the configuration file */
2246:Core/Src/bmi270/bmi2.c ****         rslt = write_config_file(dev);
2247:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
2248:Core/Src/bmi270/bmi2.c ****         {
2249:Core/Src/bmi270/bmi2.c ****             /* Check the configuration load status */
2250:Core/Src/bmi270/bmi2.c ****             rslt = bmi2_get_internal_status(&load_status, dev);
2251:Core/Src/bmi270/bmi2.c **** 
2252:Core/Src/bmi270/bmi2.c ****             load_status &= BMI2_CONFIG_LOAD_STATUS_MASK;
2253:Core/Src/bmi270/bmi2.c **** 
ARM GAS  /var/folders/gv/t2w3mcd17yl2fynvjl120d0m0000gn/T//ccrYfS3R.s 			page 41


2254:Core/Src/bmi270/bmi2.c ****             dev->load_status = load_status;
2255:Core/Src/bmi270/bmi2.c **** 
2256:Core/Src/bmi270/bmi2.c ****             /* Return error if loading not successful */
2257:Core/Src/bmi270/bmi2.c ****             if ((rslt == BMI2_OK) && (load_status != BMI2_CONFIG_LOAD_SUCCESS))
2258:Core/Src/bmi270/bmi2.c ****             {
2259:Core/Src/bmi270/bmi2.c ****                 rslt = BMI2_E_CONFIG_LOAD;
2260:Core/Src/bmi270/bmi2.c ****             }
2261:Core/Src/bmi270/bmi2.c ****         }
2262:Core/Src/bmi270/bmi2.c ****     }
2263:Core/Src/bmi270/bmi2.c ****     else
2264:Core/Src/bmi270/bmi2.c ****     {
2265:Core/Src/bmi270/bmi2.c ****         rslt = BMI2_E_NULL_PTR;
2266:Core/Src/bmi270/bmi2.c ****     }
2267:Core/Src/bmi270/bmi2.c **** 
2268:Core/Src/bmi270/bmi2.c ****     return rslt;
2269:Core/Src/bmi270/bmi2.c **** }
