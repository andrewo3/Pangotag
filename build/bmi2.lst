7489:Core/Src/bmi270/bmi2.c **** /*!
7490:Core/Src/bmi270/bmi2.c ****  * @brief This internal API is used to parse the gyroscope data from the
7491:Core/Src/bmi270/bmi2.c ****  * FIFO in headerless mode.
7492:Core/Src/bmi270/bmi2.c ****  */
7493:Core/Src/bmi270/bmi2.c **** static int8_t extract_gyro_headerless_mode(struct bmi2_sens_axes_data *gyr,
7494:Core/Src/bmi270/bmi2.c ****                                            uint16_t *gyro_length,
7495:Core/Src/bmi270/bmi2.c ****                                            struct bmi2_fifo_frame *fifo,
7496:Core/Src/bmi270/bmi2.c ****                                            const struct bmi2_dev *dev)
7497:Core/Src/bmi270/bmi2.c **** {
7498:Core/Src/bmi270/bmi2.c ****     int8_t rslt;
7499:Core/Src/bmi270/bmi2.c **** 
7500:Core/Src/bmi270/bmi2.c ****     /* Variable to index the bytes */
7501:Core/Src/bmi270/bmi2.c ****     uint16_t data_index = 0;
7502:Core/Src/bmi270/bmi2.c **** 
7503:Core/Src/bmi270/bmi2.c ****     /* Variable to index gyroscope frames */
7504:Core/Src/bmi270/bmi2.c ****     uint16_t gyro_index = 0;
7505:Core/Src/bmi270/bmi2.c **** 
7506:Core/Src/bmi270/bmi2.c ****     /* Variable to store the number of bytes to be read */
7507:Core/Src/bmi270/bmi2.c ****     uint16_t data_read_length = 0;
7508:Core/Src/bmi270/bmi2.c **** 
7509:Core/Src/bmi270/bmi2.c ****     /* Variable to define the data enable byte */
7510:Core/Src/bmi270/bmi2.c ****     uint8_t data_enable;
7511:Core/Src/bmi270/bmi2.c **** 
7512:Core/Src/bmi270/bmi2.c ****     /* Variable to hold number of bytes to skip in case dummy frame is obtained */
7513:Core/Src/bmi270/bmi2.c ****     uint8_t skip_length = 0;
7514:Core/Src/bmi270/bmi2.c **** 
7515:Core/Src/bmi270/bmi2.c ****     /* Get the number of gyro bytes to be read */
7516:Core/Src/bmi270/bmi2.c ****     rslt = parse_fifo_gyro_len(&data_index, &data_read_length, &skip_length, gyro_length, fifo);
7517:Core/Src/bmi270/bmi2.c **** 
7518:Core/Src/bmi270/bmi2.c ****     /* Convert word to byte since all sensor enables are in a byte */
7519:Core/Src/bmi270/bmi2.c ****     data_enable = (uint8_t)(fifo->data_enable >> 8);
7520:Core/Src/bmi270/bmi2.c **** 
ARM GAS  /var/folders/gv/t2w3mcd17yl2fynvjl120d0m0000gn/T//ccrYfS3R.s 			page 155


7521:Core/Src/bmi270/bmi2.c ****     for (; (data_index < data_read_length) && (rslt != BMI2_W_FIFO_EMPTY);)
7522:Core/Src/bmi270/bmi2.c ****     {
7523:Core/Src/bmi270/bmi2.c ****         rslt = check_dummy_frame(BMI2_FIFO_HEADERLESS_DUMMY_GYR, &data_index, skip_length, fifo);
7524:Core/Src/bmi270/bmi2.c **** 
7525:Core/Src/bmi270/bmi2.c ****         /* Unpack only if Valid frame is present */
7526:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
7527:Core/Src/bmi270/bmi2.c ****         {
7528:Core/Src/bmi270/bmi2.c ****             /* Unpack frame to get gyroscope data */
7529:Core/Src/bmi270/bmi2.c ****             rslt = unpack_gyro_headerless_frame(gyr, &data_index, &gyro_index, data_enable, fifo, d
7530:Core/Src/bmi270/bmi2.c **** 
7531:Core/Src/bmi270/bmi2.c ****             if (rslt != BMI2_W_FIFO_EMPTY)
7532:Core/Src/bmi270/bmi2.c ****             {
7533:Core/Src/bmi270/bmi2.c ****                 /* Check for the availability of next two bytes of FIFO data */
7534:Core/Src/bmi270/bmi2.c ****                 rslt = check_empty_fifo(&data_index, fifo);
7535:Core/Src/bmi270/bmi2.c ****             }
7536:Core/Src/bmi270/bmi2.c ****         }
7537:Core/Src/bmi270/bmi2.c ****     }
7538:Core/Src/bmi270/bmi2.c **** 
7539:Core/Src/bmi270/bmi2.c ****     /* Update number of gyroscope frames to be read */
7540:Core/Src/bmi270/bmi2.c ****     (*gyro_length) = gyro_index;
7541:Core/Src/bmi270/bmi2.c **** 
7542:Core/Src/bmi270/bmi2.c ****     /* Update the gyroscope byte index */
7543:Core/Src/bmi270/bmi2.c ****     fifo->gyr_byte_start_idx = data_index;
7544:Core/Src/bmi270/bmi2.c **** 
