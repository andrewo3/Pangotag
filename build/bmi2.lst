11397:Core/Src/bmi270/bmi2.c **** /*!
11398:Core/Src/bmi270/bmi2.c ****  * @brief This internal API is used to test gyro CRT.
11399:Core/Src/bmi270/bmi2.c ****  */
11400:Core/Src/bmi270/bmi2.c **** static int8_t gyro_crt_test(uint8_t max_burst_length, uint8_t gyro_st_crt, struct bmi2_dev *dev)
11401:Core/Src/bmi270/bmi2.c **** {
11402:Core/Src/bmi270/bmi2.c ****     int8_t rslt;
11403:Core/Src/bmi270/bmi2.c ****     int8_t rslt_crt = BMI2_OK;
11404:Core/Src/bmi270/bmi2.c ****     uint8_t cmd = BMI2_G_TRIGGER_CMD;
11405:Core/Src/bmi270/bmi2.c ****     uint8_t download_ready = 0;
11406:Core/Src/bmi270/bmi2.c **** 
11407:Core/Src/bmi270/bmi2.c ****     rslt = set_st_running(BMI2_ENABLE, dev);
11408:Core/Src/bmi270/bmi2.c **** 
11409:Core/Src/bmi270/bmi2.c ****     /* Preparing the setup */
11410:Core/Src/bmi270/bmi2.c ****     if (rslt == BMI2_OK)
11411:Core/Src/bmi270/bmi2.c ****     {
11412:Core/Src/bmi270/bmi2.c ****         rslt = crt_prepare_setup(dev);
11413:Core/Src/bmi270/bmi2.c ****     }
11414:Core/Src/bmi270/bmi2.c **** 
11415:Core/Src/bmi270/bmi2.c ****     /* Enable the gyro self-test, CRT */
11416:Core/Src/bmi270/bmi2.c ****     if (rslt == BMI2_OK)
11417:Core/Src/bmi270/bmi2.c ****     {
11418:Core/Src/bmi270/bmi2.c ****         rslt = select_self_test(gyro_st_crt, dev);
11419:Core/Src/bmi270/bmi2.c ****     }
11420:Core/Src/bmi270/bmi2.c **** 
11421:Core/Src/bmi270/bmi2.c ****     /* Check if FIFO is unchanged by checking the max burst length */
11422:Core/Src/bmi270/bmi2.c ****     if ((rslt == BMI2_OK) && (max_burst_length == 0))
11423:Core/Src/bmi270/bmi2.c ****     {
11424:Core/Src/bmi270/bmi2.c ****         /* Trigger CRT */
11425:Core/Src/bmi270/bmi2.c ****         rslt = bmi2_set_regs(BMI2_CMD_REG_ADDR, &cmd, 1, dev);
11426:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
ARM GAS  /var/folders/gv/t2w3mcd17yl2fynvjl120d0m0000gn/T//ccrYfS3R.s 			page 556


11427:Core/Src/bmi270/bmi2.c ****         {
11428:Core/Src/bmi270/bmi2.c ****             /* Wait until st_status = 0 or time out is 2 seconds */
11429:Core/Src/bmi270/bmi2.c ****             rslt = wait_st_running(BMI2_CRT_WAIT_RUNNING_RETRY_EXECUTION, dev);
11430:Core/Src/bmi270/bmi2.c **** 
11431:Core/Src/bmi270/bmi2.c ****             /* CRT Running wait & check is successful */
11432:Core/Src/bmi270/bmi2.c ****             if (rslt == BMI2_OK)
11433:Core/Src/bmi270/bmi2.c ****             {
11434:Core/Src/bmi270/bmi2.c ****                 rslt = crt_gyro_st_update_result(dev);
11435:Core/Src/bmi270/bmi2.c ****             }
11436:Core/Src/bmi270/bmi2.c ****         }
11437:Core/Src/bmi270/bmi2.c ****     }
11438:Core/Src/bmi270/bmi2.c ****     else
11439:Core/Src/bmi270/bmi2.c ****     {
11440:Core/Src/bmi270/bmi2.c ****         /* FIFO may be used */
11441:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
11442:Core/Src/bmi270/bmi2.c ****         {
11443:Core/Src/bmi270/bmi2.c ****             if (dev->read_write_len < 2)
11444:Core/Src/bmi270/bmi2.c ****             {
11445:Core/Src/bmi270/bmi2.c ****                 dev->read_write_len = 2;
11446:Core/Src/bmi270/bmi2.c ****             }
11447:Core/Src/bmi270/bmi2.c **** 
11448:Core/Src/bmi270/bmi2.c ****             if (dev->read_write_len > (BMI2_CRT_MAX_BURST_WORD_LENGTH * 2))
11449:Core/Src/bmi270/bmi2.c ****             {
11450:Core/Src/bmi270/bmi2.c ****                 dev->read_write_len = BMI2_CRT_MAX_BURST_WORD_LENGTH * 2;
11451:Core/Src/bmi270/bmi2.c ****             }
11452:Core/Src/bmi270/bmi2.c **** 
11453:Core/Src/bmi270/bmi2.c ****             /* Reset the max burst length to default value */
11454:Core/Src/bmi270/bmi2.c ****             rslt = set_maxburst_len(dev->read_write_len, dev);
11455:Core/Src/bmi270/bmi2.c ****         }
11456:Core/Src/bmi270/bmi2.c **** 
11457:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
11458:Core/Src/bmi270/bmi2.c ****         {
11459:Core/Src/bmi270/bmi2.c ****             rslt = get_rdy_for_dl(&download_ready, dev);
11460:Core/Src/bmi270/bmi2.c ****         }
11461:Core/Src/bmi270/bmi2.c **** 
11462:Core/Src/bmi270/bmi2.c ****         /* Trigger CRT  */
11463:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
11464:Core/Src/bmi270/bmi2.c ****         {
11465:Core/Src/bmi270/bmi2.c ****             rslt = bmi2_set_regs(BMI2_CMD_REG_ADDR, &cmd, 1, dev);
11466:Core/Src/bmi270/bmi2.c ****         }
11467:Core/Src/bmi270/bmi2.c **** 
