6589:Core/Src/bmi270/bmi2.c **** {
6590:Core/Src/bmi270/bmi2.c ****     /* Variable to define error */
6591:Core/Src/bmi270/bmi2.c ****     int8_t rslt = BMI2_OK;
6592:Core/Src/bmi270/bmi2.c **** 
6593:Core/Src/bmi270/bmi2.c ****     /* Array to store the register data */
6594:Core/Src/bmi270/bmi2.c ****     uint8_t reg_data[15] = { 0 };
6595:Core/Src/bmi270/bmi2.c **** 
