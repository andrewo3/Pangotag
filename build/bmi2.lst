9405:Core/Src/bmi270/bmi2.c **** /*!
9406:Core/Src/bmi270/bmi2.c ****  * @brief This internal sets configurations for performing accelerometer FOC.
9407:Core/Src/bmi270/bmi2.c ****  */
9408:Core/Src/bmi270/bmi2.c **** static int8_t set_accel_foc_config(struct bmi2_dev *dev)
9409:Core/Src/bmi270/bmi2.c **** {
9410:Core/Src/bmi270/bmi2.c ****     /* Variable to define error */
9411:Core/Src/bmi270/bmi2.c ****     int8_t rslt;
9412:Core/Src/bmi270/bmi2.c **** 
9413:Core/Src/bmi270/bmi2.c ****     /* Variable to select the sensor */
9414:Core/Src/bmi270/bmi2.c ****     uint8_t sens_list = BMI2_ACCEL;
9415:Core/Src/bmi270/bmi2.c **** 
9416:Core/Src/bmi270/bmi2.c ****     /* Variable to set the accelerometer configuration value */
9417:Core/Src/bmi270/bmi2.c ****     uint8_t acc_conf_data = BMI2_FOC_ACC_CONF_VAL;
9418:Core/Src/bmi270/bmi2.c **** 
9419:Core/Src/bmi270/bmi2.c ****     /* Disabling offset compensation */
9420:Core/Src/bmi270/bmi2.c ****     rslt = bmi2_set_accel_offset_comp(BMI2_DISABLE, dev);
9421:Core/Src/bmi270/bmi2.c ****     if (rslt == BMI2_OK)
9422:Core/Src/bmi270/bmi2.c ****     {
9423:Core/Src/bmi270/bmi2.c ****         /* Set accelerometer configurations to 50Hz, continuous mode, CIC mode */
9424:Core/Src/bmi270/bmi2.c ****         rslt = bmi2_set_regs(BMI2_ACC_CONF_ADDR, &acc_conf_data, 1, dev);
9425:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
9426:Core/Src/bmi270/bmi2.c ****         {
9427:Core/Src/bmi270/bmi2.c ****             /* Set accelerometer to normal mode by enabling it */
9428:Core/Src/bmi270/bmi2.c ****             rslt = bmi2_sensor_enable(&sens_list, 1, dev);
9429:Core/Src/bmi270/bmi2.c **** 
