9468:Core/Src/bmi270/bmi2.c **** 
9469:Core/Src/bmi270/bmi2.c ****     /* Variable to define range */
9470:Core/Src/bmi270/bmi2.c ****     uint8_t range = 0;
9471:Core/Src/bmi270/bmi2.c **** 
