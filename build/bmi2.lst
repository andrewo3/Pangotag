11527:Core/Src/bmi270/bmi2.c ****             }
11528:Core/Src/bmi270/bmi2.c ****         }
11529:Core/Src/bmi270/bmi2.c **** 
11530:Core/Src/bmi270/bmi2.c ****         avg_foc_data.x = (int16_t)(temp_foc_data.x);
11531:Core/Src/bmi270/bmi2.c ****         avg_foc_data.y = (int16_t)(temp_foc_data.y);
11532:Core/Src/bmi270/bmi2.c ****         avg_foc_data.z = (int16_t)(temp_foc_data.z);
11533:Core/Src/bmi270/bmi2.c **** 
