2111:Core/Src/bmi270/bmi2.c ****         }
2112:Core/Src/bmi270/bmi2.c **** 
2113:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
2114:Core/Src/bmi270/bmi2.c ****         {
2115:Core/Src/bmi270/bmi2.c ****             /* Write the configuration file */
2116:Core/Src/bmi270/bmi2.c ****             rslt = bmi2_write_config_file(dev);
2117:Core/Src/bmi270/bmi2.c ****         }
2118:Core/Src/bmi270/bmi2.c **** 
2119:Core/Src/bmi270/bmi2.c ****         /* Reset the sensor status flag in the device structure */
2120:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
2121:Core/Src/bmi270/bmi2.c ****         {
2122:Core/Src/bmi270/bmi2.c ****             dev->sens_en_stat = 0;
2123:Core/Src/bmi270/bmi2.c ****         }
2124:Core/Src/bmi270/bmi2.c ****     }
2125:Core/Src/bmi270/bmi2.c **** 
2126:Core/Src/bmi270/bmi2.c ****     return rslt;
2127:Core/Src/bmi270/bmi2.c **** }
