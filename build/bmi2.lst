8816:Core/Src/bmi270/bmi2.c **** /*!
8817:Core/Src/bmi270/bmi2.c ****  * @brief This internal API enables and configures the accelerometer which is
8818:Core/Src/bmi270/bmi2.c ****  * needed for self-test operation. It also sets the amplitude for the self-test.
8819:Core/Src/bmi270/bmi2.c ****  */
8820:Core/Src/bmi270/bmi2.c **** static int8_t pre_self_test_config(struct bmi2_dev *dev)
8821:Core/Src/bmi270/bmi2.c **** {
8822:Core/Src/bmi270/bmi2.c ****     /* Variable to define error */
8823:Core/Src/bmi270/bmi2.c ****     int8_t rslt;
8824:Core/Src/bmi270/bmi2.c **** 
8825:Core/Src/bmi270/bmi2.c ****     /* Structure to define sensor configurations */
8826:Core/Src/bmi270/bmi2.c ****     struct bmi2_sens_config sens_cfg;
8827:Core/Src/bmi270/bmi2.c **** 
8828:Core/Src/bmi270/bmi2.c ****     /* List the sensors to be selected */
8829:Core/Src/bmi270/bmi2.c ****     uint8_t sens_sel = BMI2_ACCEL;
8830:Core/Src/bmi270/bmi2.c **** 
8831:Core/Src/bmi270/bmi2.c ****     /* Enable accelerometer */
8832:Core/Src/bmi270/bmi2.c ****     rslt = bmi2_sensor_enable(&sens_sel, 1, dev);
8833:Core/Src/bmi270/bmi2.c ****     dev->delay_us(1000, dev->intf_ptr);
8834:Core/Src/bmi270/bmi2.c **** 
8835:Core/Src/bmi270/bmi2.c ****     /* Enable self-test amplitude */
8836:Core/Src/bmi270/bmi2.c ****     if (rslt == BMI2_OK)
8837:Core/Src/bmi270/bmi2.c ****     {
8838:Core/Src/bmi270/bmi2.c ****         rslt = set_accel_self_test_amp(BMI2_ENABLE, dev);
8839:Core/Src/bmi270/bmi2.c ****     }
8840:Core/Src/bmi270/bmi2.c **** 
8841:Core/Src/bmi270/bmi2.c ****     if (rslt == BMI2_OK)
8842:Core/Src/bmi270/bmi2.c ****     {
8843:Core/Src/bmi270/bmi2.c ****         /* Select accelerometer for sensor configurations */
8844:Core/Src/bmi270/bmi2.c ****         sens_cfg.type = BMI2_ACCEL;
8845:Core/Src/bmi270/bmi2.c **** 
8846:Core/Src/bmi270/bmi2.c ****         /* Get the default values */
8847:Core/Src/bmi270/bmi2.c ****         rslt = bmi2_get_sensor_config(&sens_cfg, 1, dev);
8848:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
8849:Core/Src/bmi270/bmi2.c ****         {
8850:Core/Src/bmi270/bmi2.c ****             /* Set the configurations required for self-test */
8851:Core/Src/bmi270/bmi2.c ****             sens_cfg.cfg.acc.odr = BMI2_ACC_ODR_1600HZ;
8852:Core/Src/bmi270/bmi2.c ****             sens_cfg.cfg.acc.bwp = BMI2_ACC_NORMAL_AVG4;
8853:Core/Src/bmi270/bmi2.c ****             sens_cfg.cfg.acc.filter_perf = BMI2_PERF_OPT_MODE;
8854:Core/Src/bmi270/bmi2.c ****             sens_cfg.cfg.acc.range = BMI2_ACC_RANGE_16G;
8855:Core/Src/bmi270/bmi2.c **** 
8856:Core/Src/bmi270/bmi2.c ****             /* Set accelerometer configurations */
8857:Core/Src/bmi270/bmi2.c ****             rslt = bmi2_set_sensor_config(&sens_cfg, 1, dev);
ARM GAS  /var/folders/gv/t2w3mcd17yl2fynvjl120d0m0000gn/T//ccrYfS3R.s 			page 249


8858:Core/Src/bmi270/bmi2.c ****         }
8859:Core/Src/bmi270/bmi2.c ****     }
8860:Core/Src/bmi270/bmi2.c **** 
8861:Core/Src/bmi270/bmi2.c ****     return rslt;
8862:Core/Src/bmi270/bmi2.c **** }
8863:Core/Src/bmi270/bmi2.c **** 
8864:Core/Src/bmi270/bmi2.c **** /*!
8865:Core/Src/bmi270/bmi2.c ****  * @brief This internal API performs the steps needed for self-test operation
8866:Core/Src/bmi270/bmi2.c ****  * before reading the accelerometer self-test data.
8867:Core/Src/bmi270/bmi2.c ****  */
8868:Core/Src/bmi270/bmi2.c **** static int8_t self_test_config(uint8_t sign, struct bmi2_dev *dev)
8869:Core/Src/bmi270/bmi2.c **** {
8870:Core/Src/bmi270/bmi2.c ****     /* Variable to define error */
8871:Core/Src/bmi270/bmi2.c ****     int8_t rslt;
8872:Core/Src/bmi270/bmi2.c **** 
8873:Core/Src/bmi270/bmi2.c ****     /* Enable the accelerometer self-test feature */
8874:Core/Src/bmi270/bmi2.c ****     rslt = set_accel_self_test_enable(BMI2_ENABLE, dev);
8875:Core/Src/bmi270/bmi2.c ****     if (rslt == BMI2_OK)
8876:Core/Src/bmi270/bmi2.c ****     {
8877:Core/Src/bmi270/bmi2.c ****         /* Selects the sign of accelerometer self-test excitation */
8878:Core/Src/bmi270/bmi2.c ****         rslt = set_acc_self_test_sign(sign, dev);
8879:Core/Src/bmi270/bmi2.c ****     }
8880:Core/Src/bmi270/bmi2.c **** 
8881:Core/Src/bmi270/bmi2.c ****     return rslt;
8882:Core/Src/bmi270/bmi2.c **** }
8883:Core/Src/bmi270/bmi2.c **** 
8884:Core/Src/bmi270/bmi2.c **** /*!
8885:Core/Src/bmi270/bmi2.c ****  * @brief This internal API enables or disables the accelerometer self-test
8886:Core/Src/bmi270/bmi2.c ****  * feature in the sensor.
8887:Core/Src/bmi270/bmi2.c ****  */
8888:Core/Src/bmi270/bmi2.c **** static int8_t set_accel_self_test_enable(uint8_t enable, struct bmi2_dev *dev)
8889:Core/Src/bmi270/bmi2.c **** {
8890:Core/Src/bmi270/bmi2.c ****     /* Variable to define error */
8891:Core/Src/bmi270/bmi2.c ****     int8_t rslt;
8892:Core/Src/bmi270/bmi2.c **** 
8893:Core/Src/bmi270/bmi2.c ****     /* Variable to define data */
8894:Core/Src/bmi270/bmi2.c ****     uint8_t data = 0;
8895:Core/Src/bmi270/bmi2.c **** 
8896:Core/Src/bmi270/bmi2.c ****     /* Enable/Disable self-test feature */
8897:Core/Src/bmi270/bmi2.c ****     rslt = bmi2_get_regs(BMI2_ACC_SELF_TEST_ADDR, &data, 1, dev);
8898:Core/Src/bmi270/bmi2.c ****     if (rslt == BMI2_OK)
8899:Core/Src/bmi270/bmi2.c ****     {
8900:Core/Src/bmi270/bmi2.c ****         data = BMI2_SET_BIT_POS0(data, BMI2_ACC_SELF_TEST_EN, enable);
8901:Core/Src/bmi270/bmi2.c ****         rslt = bmi2_set_regs(BMI2_ACC_SELF_TEST_ADDR, &data, 1, dev);
8902:Core/Src/bmi270/bmi2.c ****     }
8903:Core/Src/bmi270/bmi2.c **** 
8904:Core/Src/bmi270/bmi2.c ****     return rslt;
8905:Core/Src/bmi270/bmi2.c **** }
8906:Core/Src/bmi270/bmi2.c **** 
8907:Core/Src/bmi270/bmi2.c **** /*!
8908:Core/Src/bmi270/bmi2.c ****  * @brief This internal API selects the sign for accelerometer self-test
8909:Core/Src/bmi270/bmi2.c ****  * excitation.
