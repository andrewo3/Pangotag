9033:Core/Src/bmi270/bmi2.c **** /*!
9034:Core/Src/bmi270/bmi2.c ****  * @brief This internal API converts LSB value of accelerometer axes to form
9035:Core/Src/bmi270/bmi2.c ****  * 'g' to 'mg' for self-test.
9036:Core/Src/bmi270/bmi2.c ****  */
9037:Core/Src/bmi270/bmi2.c **** static void convert_lsb_g(const struct bmi2_selftest_delta_limit *acc_data_diff,
9038:Core/Src/bmi270/bmi2.c ****                           struct bmi2_selftest_delta_limit *acc_data_diff_mg,
9039:Core/Src/bmi270/bmi2.c ****                           const struct bmi2_dev *dev)
9040:Core/Src/bmi270/bmi2.c **** {
9041:Core/Src/bmi270/bmi2.c ****     /* Variable to define LSB/g value of axes */
9042:Core/Src/bmi270/bmi2.c ****     uint32_t lsb_per_g;
9043:Core/Src/bmi270/bmi2.c **** 
9044:Core/Src/bmi270/bmi2.c ****     /* Range considered for self-test is +/-16g */
9045:Core/Src/bmi270/bmi2.c ****     uint8_t range = BMI2_ACC_SELF_TEST_RANGE;
9046:Core/Src/bmi270/bmi2.c **** 
9047:Core/Src/bmi270/bmi2.c ****     /* lsb_per_g for the respective resolution and 16g range */
9048:Core/Src/bmi270/bmi2.c ****     lsb_per_g = (uint32_t)(power(2, dev->resolution) / (2 * range));
9049:Core/Src/bmi270/bmi2.c **** 
9050:Core/Src/bmi270/bmi2.c ****     /* Accelerometer x value in mg */
9051:Core/Src/bmi270/bmi2.c ****     acc_data_diff_mg->x = (acc_data_diff->x / (int32_t) lsb_per_g) * 1000;
9052:Core/Src/bmi270/bmi2.c **** 
9053:Core/Src/bmi270/bmi2.c ****     /* Accelerometer y value in mg */
9054:Core/Src/bmi270/bmi2.c ****     acc_data_diff_mg->y = (acc_data_diff->y / (int32_t) lsb_per_g) * 1000;
9055:Core/Src/bmi270/bmi2.c **** 
9056:Core/Src/bmi270/bmi2.c ****     /* Accelerometer z value in mg */
9057:Core/Src/bmi270/bmi2.c ****     acc_data_diff_mg->z = (acc_data_diff->z / (int32_t) lsb_per_g) * 1000;
9058:Core/Src/bmi270/bmi2.c **** }
