6634:Core/Src/bmi270/bmi2.c ****                 }
6635:Core/Src/bmi270/bmi2.c ****             }
6636:Core/Src/bmi270/bmi2.c ****         }
6637:Core/Src/bmi270/bmi2.c **** 
6638:Core/Src/bmi270/bmi2.c ****         /* Update address for the next read */
6639:Core/Src/bmi270/bmi2.c ****         reg_addr += burst_len;
6640:Core/Src/bmi270/bmi2.c **** 
6641:Core/Src/bmi270/bmi2.c ****         /* Update count for the array index */
6642:Core/Src/bmi270/bmi2.c ****         count += burst_len;
6643:Core/Src/bmi270/bmi2.c **** 
6644:Core/Src/bmi270/bmi2.c ****         /* Update no of bytes left to read */
6645:Core/Src/bmi270/bmi2.c ****         len -= read_length;
6646:Core/Src/bmi270/bmi2.c ****     }
6647:Core/Src/bmi270/bmi2.c **** 
