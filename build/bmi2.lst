10233:Core/Src/bmi270/bmi2.c ****                 if (index < ((start_index + config_file_size) - write_len))
10234:Core/Src/bmi270/bmi2.c ****                 {
10235:Core/Src/bmi270/bmi2.c ****                     last_byte_flag = 1;
10236:Core/Src/bmi270/bmi2.c ****                 }
10237:Core/Src/bmi270/bmi2.c **** 
10238:Core/Src/bmi270/bmi2.c ****                 if (rslt == BMI2_OK)
10239:Core/Src/bmi270/bmi2.c ****                 {
10240:Core/Src/bmi270/bmi2.c ****                     rslt = process_crt_download(last_byte_flag, dev);
10241:Core/Src/bmi270/bmi2.c ****                 }
