1951:Core/Src/bmi270/bmi2.c **** /*!
1952:Core/Src/bmi270/bmi2.c ****  * @brief This API reads the data from the given register address of bmi2
1953:Core/Src/bmi270/bmi2.c ****  * sensor.
1954:Core/Src/bmi270/bmi2.c ****  *
1955:Core/Src/bmi270/bmi2.c ****  * @note For most of the registers auto address increment applies, with the
1956:Core/Src/bmi270/bmi2.c ****  * exception of a few special registers, which trap the address. For e.g.,
1957:Core/Src/bmi270/bmi2.c ****  * Register address - 0x26, 0x5E.
1958:Core/Src/bmi270/bmi2.c ****  */
1959:Core/Src/bmi270/bmi2.c **** int8_t bmi2_get_regs(uint8_t reg_addr, uint8_t *data, uint16_t len, struct bmi2_dev *dev)
1960:Core/Src/bmi270/bmi2.c **** {
1961:Core/Src/bmi270/bmi2.c ****     /* Variable to define error */
1962:Core/Src/bmi270/bmi2.c ****     int8_t rslt;
1963:Core/Src/bmi270/bmi2.c **** 
1964:Core/Src/bmi270/bmi2.c ****     /* Variable to define loop */
1965:Core/Src/bmi270/bmi2.c ****     uint16_t index = 0;
1966:Core/Src/bmi270/bmi2.c **** 
1967:Core/Src/bmi270/bmi2.c ****     /* Variable to define temporary buffer */
1968:Core/Src/bmi270/bmi2.c ****     uint8_t temp_buf[BMI2_MAX_LEN];
ARM GAS  /var/folders/gv/t2w3mcd17yl2fynvjl120d0m0000gn/T//ccrYfS3R.s 			page 36


1969:Core/Src/bmi270/bmi2.c **** 
1970:Core/Src/bmi270/bmi2.c ****     /* Null-pointer check */
1971:Core/Src/bmi270/bmi2.c ****     rslt = null_ptr_check(dev);
1972:Core/Src/bmi270/bmi2.c ****     if ((rslt == BMI2_OK) && (data != NULL))
1973:Core/Src/bmi270/bmi2.c ****     {
1974:Core/Src/bmi270/bmi2.c ****         /* Configuring reg_addr for SPI Interface */
1975:Core/Src/bmi270/bmi2.c ****         if (dev->intf == BMI2_SPI_INTF)
1976:Core/Src/bmi270/bmi2.c ****         {
1977:Core/Src/bmi270/bmi2.c ****             reg_addr = (reg_addr | BMI2_SPI_RD_MASK);
1978:Core/Src/bmi270/bmi2.c ****         }
1979:Core/Src/bmi270/bmi2.c **** 
1980:Core/Src/bmi270/bmi2.c ****         dev->intf_rslt = dev->read(reg_addr, temp_buf, (len + dev->dummy_byte), dev->intf_ptr);
1981:Core/Src/bmi270/bmi2.c **** 
1982:Core/Src/bmi270/bmi2.c ****         if (dev->aps_status == BMI2_ENABLE)
1983:Core/Src/bmi270/bmi2.c ****         {
1984:Core/Src/bmi270/bmi2.c ****             dev->delay_us(450, dev->intf_ptr);
1985:Core/Src/bmi270/bmi2.c ****         }
1986:Core/Src/bmi270/bmi2.c ****         else
1987:Core/Src/bmi270/bmi2.c ****         {
1988:Core/Src/bmi270/bmi2.c ****             dev->delay_us(2, dev->intf_ptr);
1989:Core/Src/bmi270/bmi2.c ****         }
1990:Core/Src/bmi270/bmi2.c **** 
1991:Core/Src/bmi270/bmi2.c ****         if (dev->intf_rslt == BMI2_INTF_RET_SUCCESS)
1992:Core/Src/bmi270/bmi2.c ****         {
1993:Core/Src/bmi270/bmi2.c ****             /* Read the data from the position next to dummy byte */
1994:Core/Src/bmi270/bmi2.c ****             while (index < len)
1995:Core/Src/bmi270/bmi2.c ****             {
1996:Core/Src/bmi270/bmi2.c ****                 data[index] = temp_buf[index + dev->dummy_byte];
1997:Core/Src/bmi270/bmi2.c ****                 index++;
1998:Core/Src/bmi270/bmi2.c ****             }
1999:Core/Src/bmi270/bmi2.c ****         }
2000:Core/Src/bmi270/bmi2.c ****         else
2001:Core/Src/bmi270/bmi2.c ****         {
2002:Core/Src/bmi270/bmi2.c ****             rslt = BMI2_E_COM_FAIL;
2003:Core/Src/bmi270/bmi2.c ****         }
2004:Core/Src/bmi270/bmi2.c ****     }
2005:Core/Src/bmi270/bmi2.c ****     else
2006:Core/Src/bmi270/bmi2.c ****     {
2007:Core/Src/bmi270/bmi2.c ****         rslt = BMI2_E_NULL_PTR;
2008:Core/Src/bmi270/bmi2.c ****     }
2009:Core/Src/bmi270/bmi2.c **** 
2010:Core/Src/bmi270/bmi2.c ****     return rslt;
2011:Core/Src/bmi270/bmi2.c **** }
2012:Core/Src/bmi270/bmi2.c **** 
2013:Core/Src/bmi270/bmi2.c **** /*!
2014:Core/Src/bmi270/bmi2.c ****  * @brief This API writes data to the given register address of bmi2 sensor.
2015:Core/Src/bmi270/bmi2.c ****  */
2016:Core/Src/bmi270/bmi2.c **** int8_t bmi2_set_regs(uint8_t reg_addr, const uint8_t *data, uint16_t len, struct bmi2_dev *dev)
2017:Core/Src/bmi270/bmi2.c **** {
2018:Core/Src/bmi270/bmi2.c ****     /* Variable to define error */
2019:Core/Src/bmi270/bmi2.c ****     int8_t rslt;
2020:Core/Src/bmi270/bmi2.c **** 
2021:Core/Src/bmi270/bmi2.c ****     uint16_t loop;
2022:Core/Src/bmi270/bmi2.c **** 
2023:Core/Src/bmi270/bmi2.c ****     /* Null-pointer check */
2024:Core/Src/bmi270/bmi2.c ****     rslt = null_ptr_check(dev);
2025:Core/Src/bmi270/bmi2.c ****     if ((rslt == BMI2_OK) && (data != NULL))
ARM GAS  /var/folders/gv/t2w3mcd17yl2fynvjl120d0m0000gn/T//ccrYfS3R.s 			page 37


2026:Core/Src/bmi270/bmi2.c ****     {
2027:Core/Src/bmi270/bmi2.c ****         /* Configuring reg_addr for SPI Interface */
2028:Core/Src/bmi270/bmi2.c ****         if (dev->intf == BMI2_SPI_INTF)
2029:Core/Src/bmi270/bmi2.c ****         {
2030:Core/Src/bmi270/bmi2.c ****             reg_addr = (reg_addr & BMI2_SPI_WR_MASK);
2031:Core/Src/bmi270/bmi2.c ****         }
2032:Core/Src/bmi270/bmi2.c **** 
2033:Core/Src/bmi270/bmi2.c ****         /* Writing Byte by byte and delay for Low power mode of the sensor is 450 us */
2034:Core/Src/bmi270/bmi2.c ****         if (dev->aps_status == BMI2_ENABLE)
2035:Core/Src/bmi270/bmi2.c ****         {
2036:Core/Src/bmi270/bmi2.c ****             for (loop = 0; loop < len; loop++)
2037:Core/Src/bmi270/bmi2.c ****             {
2038:Core/Src/bmi270/bmi2.c ****                 dev->intf_rslt = dev->write((uint8_t)((uint16_t)reg_addr + loop), &data[loop], 1, d
2039:Core/Src/bmi270/bmi2.c ****                 dev->delay_us(BMI2_POWER_SAVE_MODE_DELAY_IN_US, dev->intf_ptr);
2040:Core/Src/bmi270/bmi2.c ****                 if (dev->intf_rslt != BMI2_INTF_RET_SUCCESS)
2041:Core/Src/bmi270/bmi2.c ****                 {
2042:Core/Src/bmi270/bmi2.c ****                     break;
2043:Core/Src/bmi270/bmi2.c ****                 }
2044:Core/Src/bmi270/bmi2.c ****             }
2045:Core/Src/bmi270/bmi2.c ****         }
2046:Core/Src/bmi270/bmi2.c ****         /* Burst write and delay for Normal mode of the sensor is 2 us */
2047:Core/Src/bmi270/bmi2.c ****         else
2048:Core/Src/bmi270/bmi2.c ****         {
2049:Core/Src/bmi270/bmi2.c ****             dev->intf_rslt = dev->write(reg_addr, data, len, dev->intf_ptr);
2050:Core/Src/bmi270/bmi2.c ****             dev->delay_us(BMI2_NORMAL_MODE_DELAY_IN_US, dev->intf_ptr);
2051:Core/Src/bmi270/bmi2.c ****         }
2052:Core/Src/bmi270/bmi2.c **** 
2053:Core/Src/bmi270/bmi2.c ****         /* Updating the advance power saver flag */
2054:Core/Src/bmi270/bmi2.c ****         if (reg_addr == BMI2_PWR_CONF_ADDR)
2055:Core/Src/bmi270/bmi2.c ****         {
2056:Core/Src/bmi270/bmi2.c ****             if (*data & BMI2_ADV_POW_EN_MASK)
2057:Core/Src/bmi270/bmi2.c ****             {
2058:Core/Src/bmi270/bmi2.c ****                 dev->aps_status = BMI2_ENABLE;
2059:Core/Src/bmi270/bmi2.c ****             }
2060:Core/Src/bmi270/bmi2.c ****             else
2061:Core/Src/bmi270/bmi2.c ****             {
2062:Core/Src/bmi270/bmi2.c ****                 dev->aps_status = BMI2_DISABLE;
2063:Core/Src/bmi270/bmi2.c ****             }
2064:Core/Src/bmi270/bmi2.c ****         }
2065:Core/Src/bmi270/bmi2.c **** 
2066:Core/Src/bmi270/bmi2.c ****         if (dev->intf_rslt != BMI2_INTF_RET_SUCCESS)
2067:Core/Src/bmi270/bmi2.c ****         {
2068:Core/Src/bmi270/bmi2.c ****             rslt = BMI2_E_COM_FAIL;
2069:Core/Src/bmi270/bmi2.c ****         }
2070:Core/Src/bmi270/bmi2.c ****     }
2071:Core/Src/bmi270/bmi2.c ****     else
2072:Core/Src/bmi270/bmi2.c ****     {
2073:Core/Src/bmi270/bmi2.c ****         rslt = BMI2_E_NULL_PTR;
2074:Core/Src/bmi270/bmi2.c ****     }
2075:Core/Src/bmi270/bmi2.c **** 
2076:Core/Src/bmi270/bmi2.c ****     return rslt;
2077:Core/Src/bmi270/bmi2.c **** }
