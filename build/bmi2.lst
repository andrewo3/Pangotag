9476:Core/Src/bmi270/bmi2.c ****     struct bmi2_accel_offset offset = { 0, 0, 0 };
9477:Core/Src/bmi270/bmi2.c **** 
9478:Core/Src/bmi270/bmi2.c ****     /* Variable tries max 5 times for interrupt then generates timeout */
9479:Core/Src/bmi270/bmi2.c ****     uint8_t try_cnt;
9480:Core/Src/bmi270/bmi2.c **** 
9481:Core/Src/bmi270/bmi2.c ****     for (loop = 0; loop < 128; loop++)
9482:Core/Src/bmi270/bmi2.c ****     {
9483:Core/Src/bmi270/bmi2.c ****         try_cnt = 5;
9484:Core/Src/bmi270/bmi2.c ****         while (try_cnt && (!(reg_status & BMI2_DRDY_ACC)))
9485:Core/Src/bmi270/bmi2.c ****         {
9486:Core/Src/bmi270/bmi2.c ****             /* 20ms delay for 50Hz ODR */
9487:Core/Src/bmi270/bmi2.c ****             dev->delay_us(20000, dev->intf_ptr);
9488:Core/Src/bmi270/bmi2.c ****             rslt = bmi2_get_status(&reg_status, dev);
9489:Core/Src/bmi270/bmi2.c ****             try_cnt--;
9490:Core/Src/bmi270/bmi2.c ****         }
9491:Core/Src/bmi270/bmi2.c **** 
9492:Core/Src/bmi270/bmi2.c ****         if ((rslt == BMI2_OK) && (reg_status & BMI2_DRDY_ACC))
9493:Core/Src/bmi270/bmi2.c ****         {
9494:Core/Src/bmi270/bmi2.c ****             rslt = read_accel_xyz(&accel_value[loop], dev);
9495:Core/Src/bmi270/bmi2.c ****         }
9496:Core/Src/bmi270/bmi2.c **** 
9497:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
ARM GAS  /var/folders/gv/t2w3mcd17yl2fynvjl120d0m0000gn/T//ccrYfS3R.s 			page 310


9498:Core/Src/bmi270/bmi2.c ****         {
9499:Core/Src/bmi270/bmi2.c ****             rslt = read_accel_xyz(&accel_value[loop], dev);
9500:Core/Src/bmi270/bmi2.c ****         }
9501:Core/Src/bmi270/bmi2.c **** 
9502:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
9503:Core/Src/bmi270/bmi2.c ****         {
9504:Core/Src/bmi270/bmi2.c ****             /* Store the data in a temporary structure */
9505:Core/Src/bmi270/bmi2.c ****             temp.x = temp.x + (int32_t)accel_value[loop].x;
9506:Core/Src/bmi270/bmi2.c ****             temp.y = temp.y + (int32_t)accel_value[loop].y;
9507:Core/Src/bmi270/bmi2.c ****             temp.z = temp.z + (int32_t)accel_value[loop].z;
9508:Core/Src/bmi270/bmi2.c ****         }
9509:Core/Src/bmi270/bmi2.c ****         else
9510:Core/Src/bmi270/bmi2.c ****         {
9511:Core/Src/bmi270/bmi2.c ****             break;
9512:Core/Src/bmi270/bmi2.c ****         }
9513:Core/Src/bmi270/bmi2.c ****     }
9514:Core/Src/bmi270/bmi2.c **** 
9515:Core/Src/bmi270/bmi2.c ****     if (rslt == BMI2_OK)
9516:Core/Src/bmi270/bmi2.c ****     {
9517:Core/Src/bmi270/bmi2.c ****         /* Take average of x, y and z data for lesser noise */
9518:Core/Src/bmi270/bmi2.c ****         accel_avg.x = (int16_t)(temp.x / 128);
9519:Core/Src/bmi270/bmi2.c ****         accel_avg.y = (int16_t)(temp.y / 128);
9520:Core/Src/bmi270/bmi2.c ****         accel_avg.z = (int16_t)(temp.z / 128);
9521:Core/Src/bmi270/bmi2.c **** 
9522:Core/Src/bmi270/bmi2.c ****         /* Get the exact range value */
9523:Core/Src/bmi270/bmi2.c ****         map_accel_range(acc_cfg->range, &range);
9524:Core/Src/bmi270/bmi2.c **** 
9525:Core/Src/bmi270/bmi2.c ****         /* Get the smallest possible measurable acceleration level given the range and
9526:Core/Src/bmi270/bmi2.c ****          * resolution */
9527:Core/Src/bmi270/bmi2.c ****         lsb_per_g = (uint16_t)(power(2, dev->resolution) / (2 * range));
9528:Core/Src/bmi270/bmi2.c **** 
9529:Core/Src/bmi270/bmi2.c ****         /* Compensate acceleration data against gravity */
9530:Core/Src/bmi270/bmi2.c ****         comp_for_gravity(lsb_per_g, accel_g_value, &accel_avg, &delta);
9531:Core/Src/bmi270/bmi2.c **** 
9532:Core/Src/bmi270/bmi2.c ****         /* Scale according to offset register resolution */
9533:Core/Src/bmi270/bmi2.c ****         scale_accel_offset(range, &delta, &offset);
9534:Core/Src/bmi270/bmi2.c **** 
9535:Core/Src/bmi270/bmi2.c ****         /* Invert the accelerometer offset data */
9536:Core/Src/bmi270/bmi2.c ****         invert_accel_offset(&offset);
9537:Core/Src/bmi270/bmi2.c **** 
9538:Core/Src/bmi270/bmi2.c ****         /* Write offset data in the offset compensation register */
9539:Core/Src/bmi270/bmi2.c ****         rslt = write_accel_offset(&offset, dev);
9540:Core/Src/bmi270/bmi2.c **** 
9541:Core/Src/bmi270/bmi2.c ****         /* Enable offset compensation */
9542:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
9543:Core/Src/bmi270/bmi2.c ****         {
9544:Core/Src/bmi270/bmi2.c ****             rslt = bmi2_set_accel_offset_comp(BMI2_ENABLE, dev);
9545:Core/Src/bmi270/bmi2.c ****         }
9546:Core/Src/bmi270/bmi2.c ****     }
9547:Core/Src/bmi270/bmi2.c **** 
9548:Core/Src/bmi270/bmi2.c ****     return rslt;
9549:Core/Src/bmi270/bmi2.c **** }
