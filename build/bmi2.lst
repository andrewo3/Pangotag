10455:Core/Src/bmi270/bmi2.c **** static int8_t crt_gyro_st_update_result(struct bmi2_dev *dev)
10456:Core/Src/bmi270/bmi2.c **** {
10457:Core/Src/bmi270/bmi2.c ****     int8_t rslt;
10458:Core/Src/bmi270/bmi2.c ****     struct bmi2_gyr_user_gain_status user_gain_stat = { 0, 0, 0, 0 };
