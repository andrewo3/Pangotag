10483:Core/Src/bmi270/bmi2.c ****                 {
10484:Core/Src/bmi270/bmi2.c ****                     rslt = BMI2_E_DL_ERROR;
10485:Core/Src/bmi270/bmi2.c ****                 }
10486:Core/Src/bmi270/bmi2.c **** 
10487:Core/Src/bmi270/bmi2.c ****                 break;
10488:Core/Src/bmi270/bmi2.c ****             case BMI2_G_TRIGGER_ABORT_ERROR:
10489:Core/Src/bmi270/bmi2.c **** 
10490:Core/Src/bmi270/bmi2.c ****                 /* Command is aborted either by host via the block bit or due to motion
10491:Core/Src/bmi270/bmi2.c ****                  * detection. Keep non zero value for Max Burst Length
10492:Core/Src/bmi270/bmi2.c ****                  */
10493:Core/Src/bmi270/bmi2.c ****                 rslt = set_maxburst_len(dev->read_write_len, dev);
10494:Core/Src/bmi270/bmi2.c ****                 if (rslt == BMI2_OK)
10495:Core/Src/bmi270/bmi2.c ****                 {
10496:Core/Src/bmi270/bmi2.c ****                     rslt = BMI2_E_ABORT_ERROR;
10497:Core/Src/bmi270/bmi2.c ****                 }
10498:Core/Src/bmi270/bmi2.c **** 
10499:Core/Src/bmi270/bmi2.c ****                 break;
10500:Core/Src/bmi270/bmi2.c **** 
10501:Core/Src/bmi270/bmi2.c ****             case BMI2_G_TRIGGER_PRECON_ERROR:
10502:Core/Src/bmi270/bmi2.c **** 
10503:Core/Src/bmi270/bmi2.c ****                 /* Pre-condition to start the feature was not completed. */
10504:Core/Src/bmi270/bmi2.c ****                 rslt = BMI2_E_PRECON_ERROR;
10505:Core/Src/bmi270/bmi2.c ****                 break;
10506:Core/Src/bmi270/bmi2.c **** 
10507:Core/Src/bmi270/bmi2.c ****             default:
