10909:Core/Src/bmi270/bmi2.c **** /*! @brief This api is used for programming the non volatile memory(nvm) */
10910:Core/Src/bmi270/bmi2.c **** int8_t bmi2_nvm_prog(struct bmi2_dev *dev)
10911:Core/Src/bmi270/bmi2.c **** {
10912:Core/Src/bmi270/bmi2.c ****     int8_t rslt = BMI2_OK;
10913:Core/Src/bmi270/bmi2.c **** 
10914:Core/Src/bmi270/bmi2.c ****     /* Variable to get the status of advance power save */
10915:Core/Src/bmi270/bmi2.c ****     uint8_t aps_stat;
10916:Core/Src/bmi270/bmi2.c ****     uint8_t status;
10917:Core/Src/bmi270/bmi2.c ****     uint8_t cmd_rdy;
10918:Core/Src/bmi270/bmi2.c ****     uint8_t reg_data;
10919:Core/Src/bmi270/bmi2.c ****     uint8_t write_timeout = 100;
10920:Core/Src/bmi270/bmi2.c **** 
10921:Core/Src/bmi270/bmi2.c ****     /* Get status of advance power save mode */
10922:Core/Src/bmi270/bmi2.c ****     aps_stat = dev->aps_status;
10923:Core/Src/bmi270/bmi2.c ****     if (aps_stat == BMI2_ENABLE)
10924:Core/Src/bmi270/bmi2.c ****     {
10925:Core/Src/bmi270/bmi2.c ****         /* Disable advance power save if enabled */
10926:Core/Src/bmi270/bmi2.c ****         rslt = bmi2_set_adv_power_save(BMI2_DISABLE, dev);
10927:Core/Src/bmi270/bmi2.c ****     }
10928:Core/Src/bmi270/bmi2.c **** 
10929:Core/Src/bmi270/bmi2.c ****     /* Check the Write status and proceed only if there is no ongoing write cycle */
10930:Core/Src/bmi270/bmi2.c ****     if (rslt == BMI2_OK)
10931:Core/Src/bmi270/bmi2.c ****     {
10932:Core/Src/bmi270/bmi2.c ****         rslt = bmi2_get_status(&status, dev);
10933:Core/Src/bmi270/bmi2.c **** 
10934:Core/Src/bmi270/bmi2.c ****         cmd_rdy = BMI2_GET_BITS(status, BMI2_CMD_RDY);
10935:Core/Src/bmi270/bmi2.c ****         if (cmd_rdy)
10936:Core/Src/bmi270/bmi2.c ****         {
10937:Core/Src/bmi270/bmi2.c ****             rslt = set_nvm_prep_prog(BMI2_ENABLE, dev);
10938:Core/Src/bmi270/bmi2.c ****             if (rslt == BMI2_OK)
ARM GAS  /var/folders/gv/t2w3mcd17yl2fynvjl120d0m0000gn/T//ccrYfS3R.s 			page 345


10939:Core/Src/bmi270/bmi2.c ****             {
10940:Core/Src/bmi270/bmi2.c ****                 dev->delay_us(40000, dev->intf_ptr);
10941:Core/Src/bmi270/bmi2.c **** 
10942:Core/Src/bmi270/bmi2.c ****                 /* Set the NVM_CONF.nvm_prog_en bit in order to enable the NVM
10943:Core/Src/bmi270/bmi2.c ****                  * programming */
10944:Core/Src/bmi270/bmi2.c ****                 reg_data = BMI2_NVM_UNLOCK_ENABLE;
10945:Core/Src/bmi270/bmi2.c ****                 rslt = bmi2_set_regs(BMI2_NVM_CONF_ADDR, &reg_data, 1, dev);
10946:Core/Src/bmi270/bmi2.c ****                 if (rslt == BMI2_OK)
10947:Core/Src/bmi270/bmi2.c ****                 {
10948:Core/Src/bmi270/bmi2.c ****                     /* Send NVM prog command to command register */
10949:Core/Src/bmi270/bmi2.c ****                     reg_data = BMI2_NVM_PROG_CMD;
10950:Core/Src/bmi270/bmi2.c ****                     rslt = bmi2_set_regs(BMI2_CMD_REG_ADDR, &reg_data, 1, dev);
10951:Core/Src/bmi270/bmi2.c ****                 }
10952:Core/Src/bmi270/bmi2.c **** 
10953:Core/Src/bmi270/bmi2.c ****                 /* Wait till write operation is completed */
10954:Core/Src/bmi270/bmi2.c ****                 if (rslt == BMI2_OK)
10955:Core/Src/bmi270/bmi2.c ****                 {
10956:Core/Src/bmi270/bmi2.c ****                     while (write_timeout--)
10957:Core/Src/bmi270/bmi2.c ****                     {
10958:Core/Src/bmi270/bmi2.c ****                         rslt = bmi2_get_status(&status, dev);
10959:Core/Src/bmi270/bmi2.c ****                         if (rslt == BMI2_OK)
10960:Core/Src/bmi270/bmi2.c ****                         {
10961:Core/Src/bmi270/bmi2.c ****                             cmd_rdy = BMI2_GET_BITS(status, BMI2_CMD_RDY);
10962:Core/Src/bmi270/bmi2.c **** 
10963:Core/Src/bmi270/bmi2.c ****                             /* Nvm is complete once cmd_rdy is 1, break if 1 */
10964:Core/Src/bmi270/bmi2.c ****                             if (cmd_rdy)
10965:Core/Src/bmi270/bmi2.c ****                             {
10966:Core/Src/bmi270/bmi2.c ****                                 break;
10967:Core/Src/bmi270/bmi2.c ****                             }
10968:Core/Src/bmi270/bmi2.c **** 
10969:Core/Src/bmi270/bmi2.c ****                             /* Wait till cmd_rdy becomes 1 indicating
10970:Core/Src/bmi270/bmi2.c ****                              * nvm process completes */
10971:Core/Src/bmi270/bmi2.c ****                             dev->delay_us(20000, dev->intf_ptr);
10972:Core/Src/bmi270/bmi2.c ****                         }
10973:Core/Src/bmi270/bmi2.c ****                     }
10974:Core/Src/bmi270/bmi2.c ****                 }
10975:Core/Src/bmi270/bmi2.c **** 
10976:Core/Src/bmi270/bmi2.c ****                 if ((rslt == BMI2_OK) && (cmd_rdy != BMI2_TRUE))
10977:Core/Src/bmi270/bmi2.c ****                 {
10978:Core/Src/bmi270/bmi2.c ****                     rslt = BMI2_E_WRITE_CYCLE_ONGOING;
10979:Core/Src/bmi270/bmi2.c ****                 }
10980:Core/Src/bmi270/bmi2.c ****             }
10981:Core/Src/bmi270/bmi2.c ****         }
10982:Core/Src/bmi270/bmi2.c ****         else
10983:Core/Src/bmi270/bmi2.c ****         {
10984:Core/Src/bmi270/bmi2.c ****             rslt = BMI2_E_WRITE_CYCLE_ONGOING;
10985:Core/Src/bmi270/bmi2.c ****         }
10986:Core/Src/bmi270/bmi2.c ****     }
10987:Core/Src/bmi270/bmi2.c **** 
10988:Core/Src/bmi270/bmi2.c ****     if (rslt == BMI2_OK)
10989:Core/Src/bmi270/bmi2.c ****     {
10990:Core/Src/bmi270/bmi2.c ****         /* perform soft reset */
10991:Core/Src/bmi270/bmi2.c ****         rslt = bmi2_soft_reset(dev);
10992:Core/Src/bmi270/bmi2.c ****     }
10993:Core/Src/bmi270/bmi2.c **** 
10994:Core/Src/bmi270/bmi2.c ****     return rslt;
