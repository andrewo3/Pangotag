9373:Core/Src/bmi270/bmi2.c **** /*!
9374:Core/Src/bmi270/bmi2.c ****  * @brief This internal API saves the configurations before performing FOC.
9375:Core/Src/bmi270/bmi2.c ****  */
9376:Core/Src/bmi270/bmi2.c **** static int8_t save_accel_foc_config(struct bmi2_accel_config *acc_cfg,
9377:Core/Src/bmi270/bmi2.c ****                                     uint8_t *aps,
9378:Core/Src/bmi270/bmi2.c ****                                     uint8_t *acc_en,
9379:Core/Src/bmi270/bmi2.c ****                                     struct bmi2_dev *dev)
9380:Core/Src/bmi270/bmi2.c **** {
9381:Core/Src/bmi270/bmi2.c ****     /* Variable to define error */
9382:Core/Src/bmi270/bmi2.c ****     int8_t rslt;
9383:Core/Src/bmi270/bmi2.c **** 
ARM GAS  /var/folders/gv/t2w3mcd17yl2fynvjl120d0m0000gn/T//ccrYfS3R.s 			page 308


9384:Core/Src/bmi270/bmi2.c ****     /* Variable to get the status from PWR_CTRL register */
9385:Core/Src/bmi270/bmi2.c ****     uint8_t pwr_ctrl_data = 0;
9386:Core/Src/bmi270/bmi2.c **** 
9387:Core/Src/bmi270/bmi2.c ****     /* Get accelerometer configurations to be saved */
9388:Core/Src/bmi270/bmi2.c ****     rslt = get_accel_config(acc_cfg, dev);
9389:Core/Src/bmi270/bmi2.c ****     if (rslt == BMI2_OK)
9390:Core/Src/bmi270/bmi2.c ****     {
9391:Core/Src/bmi270/bmi2.c ****         /* Get accelerometer enable status to be saved */
9392:Core/Src/bmi270/bmi2.c ****         rslt = bmi2_get_regs(BMI2_PWR_CTRL_ADDR, &pwr_ctrl_data, 1, dev);
9393:Core/Src/bmi270/bmi2.c ****         *acc_en = BMI2_GET_BITS(pwr_ctrl_data, BMI2_ACC_EN);
9394:Core/Src/bmi270/bmi2.c **** 
9395:Core/Src/bmi270/bmi2.c ****         /* Get advance power save mode to be saved */
9396:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
9397:Core/Src/bmi270/bmi2.c ****         {
9398:Core/Src/bmi270/bmi2.c ****             rslt = bmi2_get_adv_power_save(aps, dev);
9399:Core/Src/bmi270/bmi2.c ****         }
9400:Core/Src/bmi270/bmi2.c ****     }
9401:Core/Src/bmi270/bmi2.c **** 
9402:Core/Src/bmi270/bmi2.c ****     return rslt;
9403:Core/Src/bmi270/bmi2.c **** }
