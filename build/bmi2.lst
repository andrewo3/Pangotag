8204:Core/Src/bmi270/bmi2.c ****  */
8205:Core/Src/bmi270/bmi2.c **** static int8_t extract_aux_header_mode(struct bmi2_aux_fifo_data *aux,
8206:Core/Src/bmi270/bmi2.c ****                                       uint16_t *aux_len,
8207:Core/Src/bmi270/bmi2.c ****                                       struct bmi2_fifo_frame *fifo,
8208:Core/Src/bmi270/bmi2.c ****                                       const struct bmi2_dev *dev)
8209:Core/Src/bmi270/bmi2.c **** {
8210:Core/Src/bmi270/bmi2.c ****     /* Variable to define error */
