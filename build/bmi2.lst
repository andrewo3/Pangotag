10676:Core/Src/bmi270/bmi2.c ****     /* Initialize feature configuration for nvm preparation*/
10677:Core/Src/bmi270/bmi2.c ****     struct bmi2_feature_config nvm_config = { 0, 0, 0 };
10678:Core/Src/bmi270/bmi2.c **** 
10679:Core/Src/bmi270/bmi2.c ****     /* Search for bmi2 gyro self offset correction feature as nvm program preparation feature is
