10509:Core/Src/bmi270/bmi2.c **** 
10510:Core/Src/bmi270/bmi2.c ****                 break;
10511:Core/Src/bmi270/bmi2.c ****         }
10512:Core/Src/bmi270/bmi2.c ****     }
10513:Core/Src/bmi270/bmi2.c **** 
10514:Core/Src/bmi270/bmi2.c ****     return rslt;
10515:Core/Src/bmi270/bmi2.c **** }
