4591:Core/Src/bmi270/bmi2.c ****     }
4592:Core/Src/bmi270/bmi2.c **** 
4593:Core/Src/bmi270/bmi2.c ****     return rslt;
4594:Core/Src/bmi270/bmi2.c **** }
