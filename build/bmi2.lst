2079:Core/Src/bmi270/bmi2.c **** /*!
2080:Core/Src/bmi270/bmi2.c ****  * @brief This API resets bmi2 sensor. All registers are overwritten with
2081:Core/Src/bmi270/bmi2.c ****  * their default values.
2082:Core/Src/bmi270/bmi2.c ****  */
ARM GAS  /var/folders/gv/t2w3mcd17yl2fynvjl120d0m0000gn/T//ccrYfS3R.s 			page 38


2083:Core/Src/bmi270/bmi2.c **** int8_t bmi2_soft_reset(struct bmi2_dev *dev)
2084:Core/Src/bmi270/bmi2.c **** {
2085:Core/Src/bmi270/bmi2.c ****     /* Variable to define error */
2086:Core/Src/bmi270/bmi2.c ****     int8_t rslt;
2087:Core/Src/bmi270/bmi2.c **** 
2088:Core/Src/bmi270/bmi2.c ****     /* Variable to define soft reset value */
2089:Core/Src/bmi270/bmi2.c ****     uint8_t data = BMI2_SOFT_RESET_CMD;
2090:Core/Src/bmi270/bmi2.c **** 
2091:Core/Src/bmi270/bmi2.c ****     /* Variable to read the dummy byte */
2092:Core/Src/bmi270/bmi2.c ****     uint8_t dummy_read = 0;
2093:Core/Src/bmi270/bmi2.c **** 
2094:Core/Src/bmi270/bmi2.c ****     /* Null-pointer check */
2095:Core/Src/bmi270/bmi2.c ****     rslt = null_ptr_check(dev);
2096:Core/Src/bmi270/bmi2.c ****     if (rslt == BMI2_OK)
2097:Core/Src/bmi270/bmi2.c ****     {
2098:Core/Src/bmi270/bmi2.c ****         /* Reset bmi2 device */
2099:Core/Src/bmi270/bmi2.c ****         rslt = bmi2_set_regs(BMI2_CMD_REG_ADDR, &data, 1, dev);
2100:Core/Src/bmi270/bmi2.c ****         dev->delay_us(2000, dev->intf_ptr);
2101:Core/Src/bmi270/bmi2.c **** 
2102:Core/Src/bmi270/bmi2.c ****         /* Set APS flag as after soft reset the sensor is on advance power save mode */
2103:Core/Src/bmi270/bmi2.c ****         dev->aps_status = BMI2_ENABLE;
2104:Core/Src/bmi270/bmi2.c **** 
2105:Core/Src/bmi270/bmi2.c ****         /* Performing a dummy read to bring interface back to SPI from
2106:Core/Src/bmi270/bmi2.c ****          * I2C after a soft-reset
2107:Core/Src/bmi270/bmi2.c ****          */
