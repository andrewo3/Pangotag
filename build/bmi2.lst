11514:Core/Src/bmi270/bmi2.c ****         {
11515:Core/Src/bmi270/bmi2.c ****             /* Taking modulus to make negative values as positive */
11516:Core/Src/bmi270/bmi2.c ****             if ((accel_g_axis->x == 1) && (accel_g_axis->sign == 1))
11517:Core/Src/bmi270/bmi2.c ****             {
