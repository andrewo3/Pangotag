10683:Core/Src/bmi270/bmi2.c ****     if (feat_found)
10684:Core/Src/bmi270/bmi2.c ****     {
10685:Core/Src/bmi270/bmi2.c ****         /* Get the configuration from the page where nvm preparation feature enable feature
10686:Core/Src/bmi270/bmi2.c ****          * resides */
