4534:Core/Src/bmi270/bmi2.c ****     /* Variable to mask interrupt pin 1 - lower nibble */
4535:Core/Src/bmi270/bmi2.c ****     uint8_t int1_mask = data_int;
4536:Core/Src/bmi270/bmi2.c **** 
4537:Core/Src/bmi270/bmi2.c ****     /* Variable to mask interrupt pin 2 - higher nibble */
4538:Core/Src/bmi270/bmi2.c ****     uint8_t int2_mask = (uint8_t)(data_int << 4);
4539:Core/Src/bmi270/bmi2.c **** 
4540:Core/Src/bmi270/bmi2.c ****     /* Variable to store register data */
4541:Core/Src/bmi270/bmi2.c ****     uint8_t reg_data = 0;
4542:Core/Src/bmi270/bmi2.c **** 
4543:Core/Src/bmi270/bmi2.c ****     /* Read interrupt map1 and map2 and register */
4544:Core/Src/bmi270/bmi2.c ****     rslt = bmi2_get_regs(BMI2_INT_MAP_DATA_ADDR, &reg_data, 1, dev);
4545:Core/Src/bmi270/bmi2.c ****     if (rslt == BMI2_OK)
4546:Core/Src/bmi270/bmi2.c ****     {
4547:Core/Src/bmi270/bmi2.c ****         if (int_pin < BMI2_INT_PIN_MAX)
4548:Core/Src/bmi270/bmi2.c ****         {
4549:Core/Src/bmi270/bmi2.c ****             switch (int_pin)
4550:Core/Src/bmi270/bmi2.c ****             {
4551:Core/Src/bmi270/bmi2.c ****                 case BMI2_INT_NONE:
4552:Core/Src/bmi270/bmi2.c **** 
4553:Core/Src/bmi270/bmi2.c ****                     /* Un-Map the corresponding data
4554:Core/Src/bmi270/bmi2.c ****                      * interrupt to both interrupt pin 1 and 2
4555:Core/Src/bmi270/bmi2.c ****                      */
4556:Core/Src/bmi270/bmi2.c ****                     reg_data &= ~(int1_mask | int2_mask);
4557:Core/Src/bmi270/bmi2.c ****                     break;
4558:Core/Src/bmi270/bmi2.c ****                 case BMI2_INT1:
4559:Core/Src/bmi270/bmi2.c **** 
4560:Core/Src/bmi270/bmi2.c ****                     /* Map the corresponding data interrupt to
4561:Core/Src/bmi270/bmi2.c ****                      * interrupt pin 1
4562:Core/Src/bmi270/bmi2.c ****                      */
4563:Core/Src/bmi270/bmi2.c ****                     reg_data |= int1_mask;
4564:Core/Src/bmi270/bmi2.c ****                     break;
4565:Core/Src/bmi270/bmi2.c ****                 case BMI2_INT2:
4566:Core/Src/bmi270/bmi2.c **** 
4567:Core/Src/bmi270/bmi2.c ****                     /* Map the corresponding data interrupt to
4568:Core/Src/bmi270/bmi2.c ****                      * interrupt pin 2
4569:Core/Src/bmi270/bmi2.c ****                      */
4570:Core/Src/bmi270/bmi2.c ****                     reg_data |= int2_mask;
4571:Core/Src/bmi270/bmi2.c ****                     break;
4572:Core/Src/bmi270/bmi2.c ****                 case BMI2_INT_BOTH:
4573:Core/Src/bmi270/bmi2.c **** 
4574:Core/Src/bmi270/bmi2.c ****                     /* Map the corresponding data
4575:Core/Src/bmi270/bmi2.c ****                      * interrupt to both interrupt pin 1 and 2
4576:Core/Src/bmi270/bmi2.c ****                      */
4577:Core/Src/bmi270/bmi2.c ****                     reg_data |= (int1_mask | int2_mask);
4578:Core/Src/bmi270/bmi2.c ****                     break;
4579:Core/Src/bmi270/bmi2.c ****                 default:
4580:Core/Src/bmi270/bmi2.c ****                     break;
4581:Core/Src/bmi270/bmi2.c ****             }
4582:Core/Src/bmi270/bmi2.c **** 
4583:Core/Src/bmi270/bmi2.c ****             /* Set the interrupts in the map register */
4584:Core/Src/bmi270/bmi2.c ****             rslt = bmi2_set_regs(BMI2_INT_MAP_DATA_ADDR, &reg_data, 1, dev);
4585:Core/Src/bmi270/bmi2.c ****         }
4586:Core/Src/bmi270/bmi2.c ****         else
4587:Core/Src/bmi270/bmi2.c ****         {
4588:Core/Src/bmi270/bmi2.c ****             /* Return error if invalid pin selection */
4589:Core/Src/bmi270/bmi2.c ****             rslt = BMI2_E_INVALID_INT_PIN;
4590:Core/Src/bmi270/bmi2.c ****         }
