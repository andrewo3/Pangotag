5675:Core/Src/bmi270/bmi2.c **** /*!
5676:Core/Src/bmi270/bmi2.c ****  * @brief This internal API loads the configuration file.
5677:Core/Src/bmi270/bmi2.c ****  */
5678:Core/Src/bmi270/bmi2.c **** static int8_t upload_file(const uint8_t *config_data, uint16_t index, uint16_t write_len, struct bm
5679:Core/Src/bmi270/bmi2.c **** {
5680:Core/Src/bmi270/bmi2.c ****     /* Variable to define error */
5681:Core/Src/bmi270/bmi2.c ****     int8_t rslt;
5682:Core/Src/bmi270/bmi2.c **** 
5683:Core/Src/bmi270/bmi2.c ****     /* Array to store address */
5684:Core/Src/bmi270/bmi2.c ****     uint8_t addr_array[2] = { 0 };
5685:Core/Src/bmi270/bmi2.c **** 
5686:Core/Src/bmi270/bmi2.c ****     if (config_data != NULL)
5687:Core/Src/bmi270/bmi2.c ****     {
5688:Core/Src/bmi270/bmi2.c ****         /* Store 0 to 3 bits of address in first byte */
5689:Core/Src/bmi270/bmi2.c ****         addr_array[0] = (uint8_t)((index / 2) & 0x0F);
5690:Core/Src/bmi270/bmi2.c **** 
5691:Core/Src/bmi270/bmi2.c ****         /* Store 4 to 11 bits of address in the second byte */
5692:Core/Src/bmi270/bmi2.c ****         addr_array[1] = (uint8_t)((index / 2) >> 4);
5693:Core/Src/bmi270/bmi2.c **** 
5694:Core/Src/bmi270/bmi2.c ****         /* Write the 2 bytes of address in consecutive locations */
5695:Core/Src/bmi270/bmi2.c ****         rslt = bmi2_set_regs(BMI2_INIT_ADDR_0, addr_array, 2, dev);
5696:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
5697:Core/Src/bmi270/bmi2.c ****         {
5698:Core/Src/bmi270/bmi2.c ****             /* Burst write configuration file data corresponding to user set length */
5699:Core/Src/bmi270/bmi2.c ****             rslt = bmi2_set_regs(BMI2_INIT_DATA_ADDR, (uint8_t *)config_data, write_len, dev);
5700:Core/Src/bmi270/bmi2.c ****         }
5701:Core/Src/bmi270/bmi2.c ****     }
5702:Core/Src/bmi270/bmi2.c ****     else
5703:Core/Src/bmi270/bmi2.c ****     {
5704:Core/Src/bmi270/bmi2.c ****         rslt = BMI2_E_NULL_PTR;
5705:Core/Src/bmi270/bmi2.c ****     }
5706:Core/Src/bmi270/bmi2.c **** 
5707:Core/Src/bmi270/bmi2.c ****     return rslt;
5708:Core/Src/bmi270/bmi2.c **** }
