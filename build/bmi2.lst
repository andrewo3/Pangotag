10658:Core/Src/bmi270/bmi2.c **** /*!
10659:Core/Src/bmi270/bmi2.c ****  * @brief This api is used to trigger the preparation for system for NVM programming.
10660:Core/Src/bmi270/bmi2.c ****  */
10661:Core/Src/bmi270/bmi2.c **** static int8_t set_nvm_prep_prog(uint8_t nvm_prep, struct bmi2_dev *dev)
10662:Core/Src/bmi270/bmi2.c **** {
10663:Core/Src/bmi270/bmi2.c ****     /* Variable to define error */
10664:Core/Src/bmi270/bmi2.c ****     int8_t rslt = BMI2_OK;
10665:Core/Src/bmi270/bmi2.c **** 
10666:Core/Src/bmi270/bmi2.c ****     /* Array to define the feature configuration */
10667:Core/Src/bmi270/bmi2.c ****     uint8_t feat_config[BMI2_FEAT_SIZE_IN_BYTES] = { 0 };
10668:Core/Src/bmi270/bmi2.c **** 
10669:Core/Src/bmi270/bmi2.c ****     /* Variable to define the array offset */
10670:Core/Src/bmi270/bmi2.c ****     uint8_t idx = 0;
10671:Core/Src/bmi270/bmi2.c **** 
10672:Core/Src/bmi270/bmi2.c ****     /* Variable to set flag */
10673:Core/Src/bmi270/bmi2.c ****     uint8_t feat_found;
10674:Core/Src/bmi270/bmi2.c ****     uint8_t reg_addr = 0;
