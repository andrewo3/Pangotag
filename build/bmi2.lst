6598:Core/Src/bmi270/bmi2.c **** 
6599:Core/Src/bmi270/bmi2.c ****     /* Variable to define loop */
6600:Core/Src/bmi270/bmi2.c ****     uint8_t loop = 0;
6601:Core/Src/bmi270/bmi2.c **** 
6602:Core/Src/bmi270/bmi2.c ****     /* Variable to define counts to get the correct array index */
6603:Core/Src/bmi270/bmi2.c ****     uint8_t count = 0;
6604:Core/Src/bmi270/bmi2.c **** 
6605:Core/Src/bmi270/bmi2.c ****     /* Variable to define index for the array */
6606:Core/Src/bmi270/bmi2.c ****     uint8_t idx = 0;
6607:Core/Src/bmi270/bmi2.c **** 
6608:Core/Src/bmi270/bmi2.c ****     while (len > 0)
6609:Core/Src/bmi270/bmi2.c ****     {
6610:Core/Src/bmi270/bmi2.c ****         /* Set the read address if AUX is not busy */
6611:Core/Src/bmi270/bmi2.c ****         rslt = set_if_aux_not_busy(BMI2_AUX_RD_ADDR, reg_addr, dev);
6612:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
6613:Core/Src/bmi270/bmi2.c ****         {
6614:Core/Src/bmi270/bmi2.c ****             /* Read data from bmi2 data register */
6615:Core/Src/bmi270/bmi2.c ****             rslt = bmi2_get_regs(BMI2_AUX_X_LSB_ADDR, reg_data, (uint16_t) burst_len, dev);
6616:Core/Src/bmi270/bmi2.c ****             dev->delay_us(1000, dev->intf_ptr);
6617:Core/Src/bmi270/bmi2.c ****             if (rslt == BMI2_OK)
6618:Core/Src/bmi270/bmi2.c ****             {
6619:Core/Src/bmi270/bmi2.c ****                 /* Get number of bytes to be read */
6620:Core/Src/bmi270/bmi2.c ****                 if (len < burst_len)
6621:Core/Src/bmi270/bmi2.c ****                 {
6622:Core/Src/bmi270/bmi2.c ****                     read_length = (uint8_t) len;
6623:Core/Src/bmi270/bmi2.c ****                 }
6624:Core/Src/bmi270/bmi2.c ****                 else
6625:Core/Src/bmi270/bmi2.c ****                 {
6626:Core/Src/bmi270/bmi2.c ****                     read_length = burst_len;
6627:Core/Src/bmi270/bmi2.c ****                 }
6628:Core/Src/bmi270/bmi2.c **** 
6629:Core/Src/bmi270/bmi2.c ****                 /* Update array index and store the data */
6630:Core/Src/bmi270/bmi2.c ****                 for (loop = 0; loop < read_length; loop++)
6631:Core/Src/bmi270/bmi2.c ****                 {
6632:Core/Src/bmi270/bmi2.c ****                     idx = loop + count;
