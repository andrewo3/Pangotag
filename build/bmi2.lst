10227:Core/Src/bmi270/bmi2.c ****             /* Write the configuration file for the remaining bytes */
10228:Core/Src/bmi270/bmi2.c ****             for (index = balance_byte;
10229:Core/Src/bmi270/bmi2.c ****                  (index < (start_index + config_file_size)) && (rslt == BMI2_OK);
