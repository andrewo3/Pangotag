4364:Core/Src/bmi270/bmi2.c **** /*!
4365:Core/Src/bmi270/bmi2.c ****  * @brief This API performs self-test to check the proper functionality of the
4366:Core/Src/bmi270/bmi2.c ****  * accelerometer sensor.
4367:Core/Src/bmi270/bmi2.c ****  */
4368:Core/Src/bmi270/bmi2.c **** int8_t bmi2_perform_accel_self_test(struct bmi2_dev *dev)
4369:Core/Src/bmi270/bmi2.c **** {
4370:Core/Src/bmi270/bmi2.c ****     /* Variable to define error */
4371:Core/Src/bmi270/bmi2.c ****     int8_t rslt;
4372:Core/Src/bmi270/bmi2.c **** 
4373:Core/Src/bmi270/bmi2.c ****     /* Variable to store self-test result */
4374:Core/Src/bmi270/bmi2.c ****     int8_t st_rslt = 0;
4375:Core/Src/bmi270/bmi2.c **** 
4376:Core/Src/bmi270/bmi2.c ****     /* Structure to define positive accelerometer axes */
4377:Core/Src/bmi270/bmi2.c ****     struct bmi2_sens_axes_data positive = { 0, 0, 0, 0 };
4378:Core/Src/bmi270/bmi2.c **** 
4379:Core/Src/bmi270/bmi2.c ****     /* Structure to define negative accelerometer axes */
4380:Core/Src/bmi270/bmi2.c ****     struct bmi2_sens_axes_data negative = { 0, 0, 0, 0 };
4381:Core/Src/bmi270/bmi2.c **** 
4382:Core/Src/bmi270/bmi2.c ****     /* Structure for difference of accelerometer values in g */
4383:Core/Src/bmi270/bmi2.c ****     struct bmi2_selftest_delta_limit accel_data_diff = { 0, 0, 0 };
4384:Core/Src/bmi270/bmi2.c **** 
4385:Core/Src/bmi270/bmi2.c ****     /* Structure for difference of accelerometer values in mg */
4386:Core/Src/bmi270/bmi2.c ****     struct bmi2_selftest_delta_limit accel_data_diff_mg = { 0, 0, 0 };
4387:Core/Src/bmi270/bmi2.c **** 
4388:Core/Src/bmi270/bmi2.c ****     /* Initialize the polarity of self-test as positive */
4389:Core/Src/bmi270/bmi2.c ****     int8_t sign = BMI2_ENABLE;
4390:Core/Src/bmi270/bmi2.c **** 
4391:Core/Src/bmi270/bmi2.c ****     /* Null-pointer check */
4392:Core/Src/bmi270/bmi2.c ****     rslt = null_ptr_check(dev);
4393:Core/Src/bmi270/bmi2.c ****     if (rslt == BMI2_OK)
4394:Core/Src/bmi270/bmi2.c ****     {
4395:Core/Src/bmi270/bmi2.c ****         /* Sets the configuration required before enabling self-test */
4396:Core/Src/bmi270/bmi2.c ****         rslt = pre_self_test_config(dev);
4397:Core/Src/bmi270/bmi2.c **** 
4398:Core/Src/bmi270/bmi2.c ****         /* Wait for greater than 2 milliseconds */
4399:Core/Src/bmi270/bmi2.c ****         dev->delay_us(3000, dev->intf_ptr);
4400:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
4401:Core/Src/bmi270/bmi2.c ****         {
4402:Core/Src/bmi270/bmi2.c ****             do
4403:Core/Src/bmi270/bmi2.c ****             {
4404:Core/Src/bmi270/bmi2.c ****                 /* Select positive first, then negative polarity
4405:Core/Src/bmi270/bmi2.c ****                  * after enabling self-test
4406:Core/Src/bmi270/bmi2.c ****                  */
4407:Core/Src/bmi270/bmi2.c ****                 rslt = self_test_config((uint8_t) sign, dev);
4408:Core/Src/bmi270/bmi2.c ****                 if (rslt == BMI2_OK)
4409:Core/Src/bmi270/bmi2.c ****                 {
4410:Core/Src/bmi270/bmi2.c ****                     /* Wait for greater than 50 milli-sec */
4411:Core/Src/bmi270/bmi2.c ****                     dev->delay_us(51000, dev->intf_ptr);
4412:Core/Src/bmi270/bmi2.c **** 
4413:Core/Src/bmi270/bmi2.c ****                     /* If polarity is positive */
4414:Core/Src/bmi270/bmi2.c ****                     if (sign == BMI2_ENABLE)
4415:Core/Src/bmi270/bmi2.c ****                     {
4416:Core/Src/bmi270/bmi2.c ****                         /* Read and store positive acceleration value */
4417:Core/Src/bmi270/bmi2.c ****                         rslt = read_accel_xyz(&positive, dev);
4418:Core/Src/bmi270/bmi2.c ****                     }
4419:Core/Src/bmi270/bmi2.c ****                     /* If polarity is negative */
ARM GAS  /var/folders/gv/t2w3mcd17yl2fynvjl120d0m0000gn/T//ccrYfS3R.s 			page 79


4420:Core/Src/bmi270/bmi2.c ****                     else if (sign == BMI2_DISABLE)
4421:Core/Src/bmi270/bmi2.c ****                     {
4422:Core/Src/bmi270/bmi2.c ****                         /* Read and store negative acceleration value */
4423:Core/Src/bmi270/bmi2.c ****                         rslt = read_accel_xyz(&negative, dev);
4424:Core/Src/bmi270/bmi2.c ****                     }
4425:Core/Src/bmi270/bmi2.c ****                 }
4426:Core/Src/bmi270/bmi2.c ****                 else
4427:Core/Src/bmi270/bmi2.c ****                 {
4428:Core/Src/bmi270/bmi2.c ****                     /* Break if error */
4429:Core/Src/bmi270/bmi2.c ****                     break;
4430:Core/Src/bmi270/bmi2.c ****                 }
4431:Core/Src/bmi270/bmi2.c **** 
4432:Core/Src/bmi270/bmi2.c ****                 /* Break if error */
4433:Core/Src/bmi270/bmi2.c ****                 if (rslt != BMI2_OK)
4434:Core/Src/bmi270/bmi2.c ****                 {
4435:Core/Src/bmi270/bmi2.c ****                     break;
4436:Core/Src/bmi270/bmi2.c ****                 }
4437:Core/Src/bmi270/bmi2.c **** 
4438:Core/Src/bmi270/bmi2.c ****                 /* Turn the polarity of self-test negative */
4439:Core/Src/bmi270/bmi2.c ****                 sign--;
4440:Core/Src/bmi270/bmi2.c ****             } while (sign >= 0);
4441:Core/Src/bmi270/bmi2.c ****             if (rslt == BMI2_OK)
4442:Core/Src/bmi270/bmi2.c ****             {
4443:Core/Src/bmi270/bmi2.c ****                 /* Subtract -ve acceleration values from that of +ve values */
4444:Core/Src/bmi270/bmi2.c ****                 accel_data_diff.x = (positive.x) - (negative.x);
4445:Core/Src/bmi270/bmi2.c ****                 accel_data_diff.y = (positive.y) - (negative.y);
4446:Core/Src/bmi270/bmi2.c ****                 accel_data_diff.z = (positive.z) - (negative.z);
4447:Core/Src/bmi270/bmi2.c **** 
4448:Core/Src/bmi270/bmi2.c ****                 /* Convert differences of acceleration values
4449:Core/Src/bmi270/bmi2.c ****                  * from 'g' to 'mg'
4450:Core/Src/bmi270/bmi2.c ****                  */
4451:Core/Src/bmi270/bmi2.c ****                 convert_lsb_g(&accel_data_diff, &accel_data_diff_mg, dev);
4452:Core/Src/bmi270/bmi2.c **** 
4453:Core/Src/bmi270/bmi2.c ****                 /* Validate self-test for acceleration values
4454:Core/Src/bmi270/bmi2.c ****                  * in mg and get the self-test result
4455:Core/Src/bmi270/bmi2.c ****                  */
4456:Core/Src/bmi270/bmi2.c ****                 st_rslt = validate_self_test(&accel_data_diff_mg);
4457:Core/Src/bmi270/bmi2.c **** 
4458:Core/Src/bmi270/bmi2.c ****                 /* Trigger a soft reset after performing self-test */
4459:Core/Src/bmi270/bmi2.c ****                 rslt = bmi2_soft_reset(dev);
4460:Core/Src/bmi270/bmi2.c **** 
4461:Core/Src/bmi270/bmi2.c ****                 /* Return the self-test result */
4462:Core/Src/bmi270/bmi2.c ****                 if (rslt == BMI2_OK)
4463:Core/Src/bmi270/bmi2.c ****                 {
4464:Core/Src/bmi270/bmi2.c ****                     rslt = st_rslt;
4465:Core/Src/bmi270/bmi2.c ****                 }
4466:Core/Src/bmi270/bmi2.c ****             }
4467:Core/Src/bmi270/bmi2.c ****         }
4468:Core/Src/bmi270/bmi2.c ****     }
4469:Core/Src/bmi270/bmi2.c **** 
4470:Core/Src/bmi270/bmi2.c ****     return rslt;
4471:Core/Src/bmi270/bmi2.c **** }
4472:Core/Src/bmi270/bmi2.c **** 
4473:Core/Src/bmi270/bmi2.c **** /*!
4474:Core/Src/bmi270/bmi2.c ****  * @brief This API maps/unmaps feature interrupts to that of interrupt pins.
