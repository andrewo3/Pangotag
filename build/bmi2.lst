10688:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
10689:Core/Src/bmi270/bmi2.c ****         {
10690:Core/Src/bmi270/bmi2.c ****             /* Define the offset for nvm preparation feature enable */
10691:Core/Src/bmi270/bmi2.c ****             idx = nvm_config.start_addr;
10692:Core/Src/bmi270/bmi2.c **** 
10693:Core/Src/bmi270/bmi2.c ****             /* update nvm_prog_prep  enable bit */
10694:Core/Src/bmi270/bmi2.c ****             feat_config[idx] = BMI2_SET_BITS(feat_config[idx], BMI2_NVM_PREP_FEATURE_EN, nvm_prep);
10695:Core/Src/bmi270/bmi2.c **** 
10696:Core/Src/bmi270/bmi2.c ****             /* Update the register address */
10697:Core/Src/bmi270/bmi2.c ****             reg_addr = BMI2_FEATURES_REG_ADDR + nvm_config.start_addr - 1;
10698:Core/Src/bmi270/bmi2.c **** 
10699:Core/Src/bmi270/bmi2.c ****             /* Set the configuration back to the page */
10700:Core/Src/bmi270/bmi2.c ****             rslt = bmi2_set_regs(reg_addr, &feat_config[nvm_config.start_addr - 1], 2, dev);
10701:Core/Src/bmi270/bmi2.c ****         }
10702:Core/Src/bmi270/bmi2.c ****     }
