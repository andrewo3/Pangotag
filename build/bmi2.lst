10463:Core/Src/bmi270/bmi2.c ****     if (rslt == BMI2_OK)
10464:Core/Src/bmi270/bmi2.c ****     {
10465:Core/Src/bmi270/bmi2.c ****         rslt = get_gyro_gain_update_status(&user_gain_stat, dev);
10466:Core/Src/bmi270/bmi2.c ****     }
10467:Core/Src/bmi270/bmi2.c **** 
10468:Core/Src/bmi270/bmi2.c ****     if (rslt == BMI2_OK)
10469:Core/Src/bmi270/bmi2.c ****     {
10470:Core/Src/bmi270/bmi2.c ****         switch (user_gain_stat.g_trigger_status)
10471:Core/Src/bmi270/bmi2.c ****         {
10472:Core/Src/bmi270/bmi2.c ****             case BMI2_G_TRIGGER_NO_ERROR:
10473:Core/Src/bmi270/bmi2.c **** 
10474:Core/Src/bmi270/bmi2.c ****                 /* CRT is successful - Reset the Max Burst Length */
10475:Core/Src/bmi270/bmi2.c ****                 rslt = set_maxburst_len(0, dev);
10476:Core/Src/bmi270/bmi2.c ****                 break;
10477:Core/Src/bmi270/bmi2.c **** 
10478:Core/Src/bmi270/bmi2.c ****             case BMI2_G_TRIGGER_DL_ERROR:
10479:Core/Src/bmi270/bmi2.c **** 
10480:Core/Src/bmi270/bmi2.c ****                 /* CRT is Download Error - Keep non zero value for Max Burst Length */
10481:Core/Src/bmi270/bmi2.c ****                 rslt = set_maxburst_len(dev->read_write_len, dev);
10482:Core/Src/bmi270/bmi2.c ****                 if (rslt == BMI2_OK)
