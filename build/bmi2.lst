8188:Core/Src/bmi270/bmi2.c ****             }
8189:Core/Src/bmi270/bmi2.c ****         }
8190:Core/Src/bmi270/bmi2.c ****     }
8191:Core/Src/bmi270/bmi2.c **** 
8192:Core/Src/bmi270/bmi2.c ****     /* Update number of auxiliary frames to be read */
