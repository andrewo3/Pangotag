3036:Core/Src/bmi270/bmi2.c ****         rslt = reset_fifo_frame_structure(fifo, dev);
3037:Core/Src/bmi270/bmi2.c **** 
3038:Core/Src/bmi270/bmi2.c ****         if (rslt == BMI2_OK)
3039:Core/Src/bmi270/bmi2.c ****         {
3040:Core/Src/bmi270/bmi2.c ****             /* Configuring reg_addr for SPI Interface */
3041:Core/Src/bmi270/bmi2.c ****             if (dev->intf == BMI2_SPI_INTF)
3042:Core/Src/bmi270/bmi2.c ****             {
3043:Core/Src/bmi270/bmi2.c ****                 addr = (addr | BMI2_SPI_RD_MASK);
3044:Core/Src/bmi270/bmi2.c ****             }
3045:Core/Src/bmi270/bmi2.c **** 
3046:Core/Src/bmi270/bmi2.c ****             /* Read FIFO data */
3047:Core/Src/bmi270/bmi2.c ****             dev->intf_rslt = dev->read(addr, fifo->data, (uint32_t)fifo->length, dev->intf_ptr);
3048:Core/Src/bmi270/bmi2.c **** 
3049:Core/Src/bmi270/bmi2.c ****             /* Provide delay based on advanced power saving mode status */
3050:Core/Src/bmi270/bmi2.c ****             if (dev->aps_status == BMI2_ENABLE)
3051:Core/Src/bmi270/bmi2.c ****             {
ARM GAS  /var/folders/gv/t2w3mcd17yl2fynvjl120d0m0000gn/T//ccrYfS3R.s 			page 55


3052:Core/Src/bmi270/bmi2.c ****                 dev->delay_us(450, dev->intf_ptr);
3053:Core/Src/bmi270/bmi2.c ****             }
3054:Core/Src/bmi270/bmi2.c ****             else
3055:Core/Src/bmi270/bmi2.c ****             {
3056:Core/Src/bmi270/bmi2.c ****                 dev->delay_us(2, dev->intf_ptr);
3057:Core/Src/bmi270/bmi2.c ****             }
3058:Core/Src/bmi270/bmi2.c **** 
3059:Core/Src/bmi270/bmi2.c ****             /* If interface read fails, update rslt variable with communication failure */
3060:Core/Src/bmi270/bmi2.c ****             if (dev->intf_rslt != BMI2_INTF_RET_SUCCESS)
3061:Core/Src/bmi270/bmi2.c ****             {
3062:Core/Src/bmi270/bmi2.c ****                 rslt = BMI2_E_COM_FAIL;
3063:Core/Src/bmi270/bmi2.c ****             }
3064:Core/Src/bmi270/bmi2.c **** 
3065:Core/Src/bmi270/bmi2.c ****             if (rslt == BMI2_OK)
3066:Core/Src/bmi270/bmi2.c ****             {
3067:Core/Src/bmi270/bmi2.c ****                 /* Get the set FIFO frame configurations */
3068:Core/Src/bmi270/bmi2.c ****                 rslt = bmi2_get_regs(BMI2_FIFO_CONFIG_0_ADDR, config_data, 2, dev);
3069:Core/Src/bmi270/bmi2.c ****                 if (rslt == BMI2_OK)
3070:Core/Src/bmi270/bmi2.c ****                 {
3071:Core/Src/bmi270/bmi2.c ****                     /* Get FIFO header status */
3072:Core/Src/bmi270/bmi2.c ****                     fifo->header_enable = (uint8_t)((config_data[1]) & (BMI2_FIFO_HEADER_EN >> 8));
3073:Core/Src/bmi270/bmi2.c **** 
3074:Core/Src/bmi270/bmi2.c ****                     /* Get sensor enable status, of which the data is to be read */
3075:Core/Src/bmi270/bmi2.c ****                     fifo->data_enable =
3076:Core/Src/bmi270/bmi2.c ****                         (uint16_t)(((config_data[0]) | ((uint16_t) config_data[1] << 8)) & BMI2_FIF
3077:Core/Src/bmi270/bmi2.c ****                 }
3078:Core/Src/bmi270/bmi2.c ****             }
3079:Core/Src/bmi270/bmi2.c ****             else
3080:Core/Src/bmi270/bmi2.c ****             {
3081:Core/Src/bmi270/bmi2.c ****                 rslt = BMI2_E_COM_FAIL;
3082:Core/Src/bmi270/bmi2.c ****             }
3083:Core/Src/bmi270/bmi2.c ****         }
3084:Core/Src/bmi270/bmi2.c ****     }
3085:Core/Src/bmi270/bmi2.c ****     else
3086:Core/Src/bmi270/bmi2.c ****     {
3087:Core/Src/bmi270/bmi2.c ****         rslt = BMI2_E_NULL_PTR;
3088:Core/Src/bmi270/bmi2.c ****     }
3089:Core/Src/bmi270/bmi2.c **** 
3090:Core/Src/bmi270/bmi2.c ****     return rslt;
3091:Core/Src/bmi270/bmi2.c **** }
