8163:Core/Src/bmi270/bmi2.c ****     /* Variable to define the data enable byte */
8164:Core/Src/bmi270/bmi2.c ****     uint8_t data_enable;
8165:Core/Src/bmi270/bmi2.c **** 
8166:Core/Src/bmi270/bmi2.c ****     /* Number of bytes to skip in case dummy frame is obtained */
8167:Core/Src/bmi270/bmi2.c ****     uint8_t skip_length = 0;
8168:Core/Src/bmi270/bmi2.c **** 
8169:Core/Src/bmi270/bmi2.c ****     rslt = parse_fifo_aux_len(&data_index, &data_read_length, &skip_length, aux_length, fifo);
8170:Core/Src/bmi270/bmi2.c **** 
8171:Core/Src/bmi270/bmi2.c ****     /* Convert word to byte since all sensor enables are in a byte */
8172:Core/Src/bmi270/bmi2.c ****     data_enable = (uint8_t)(fifo->data_enable >> 8);
