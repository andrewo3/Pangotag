11498:Core/Src/bmi270/bmi2.c ****                                   struct bmi2_dev *dev)
11499:Core/Src/bmi270/bmi2.c **** {
11500:Core/Src/bmi270/bmi2.c ****     /* Variable to store result of API */
11501:Core/Src/bmi270/bmi2.c ****     int8_t rslt;
11502:Core/Src/bmi270/bmi2.c **** 
11503:Core/Src/bmi270/bmi2.c ****     /* Structure to define accelerometer sensor axes */
11504:Core/Src/bmi270/bmi2.c ****     struct bmi2_sens_axes_data avg_foc_data = { 0 };
