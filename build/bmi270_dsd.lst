1831:Core/Src/bmi270/bmi270_dsd.c **** static int8_t sensor_enable(uint64_t sensor_sel, struct bmi2_dev *dev)
1832:Core/Src/bmi270/bmi270_dsd.c **** {
1833:Core/Src/bmi270/bmi270_dsd.c ****     /* Variable to define error */
