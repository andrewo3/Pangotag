1848:Core/Src/bmi270/bmi270_dsd.c ****             rslt = bmi2_set_adv_power_save(BMI2_DISABLE, dev);
1849:Core/Src/bmi270/bmi270_dsd.c ****         }
1850:Core/Src/bmi270/bmi270_dsd.c **** 
