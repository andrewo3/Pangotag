1908:Core/Src/bmi270/bmi270_dsd.c **** /*!
1909:Core/Src/bmi270/bmi270_dsd.c ****  * @brief This internal API is used to enable/disable any motion feature.
1910:Core/Src/bmi270/bmi270_dsd.c ****  */
1911:Core/Src/bmi270/bmi270_dsd.c **** static int8_t set_any_motion(uint8_t enable, struct bmi2_dev *dev)
1912:Core/Src/bmi270/bmi270_dsd.c **** {
1913:Core/Src/bmi270/bmi270_dsd.c ****     /* Variable to define error */
1914:Core/Src/bmi270/bmi270_dsd.c ****     int8_t rslt;
1915:Core/Src/bmi270/bmi270_dsd.c **** 
1916:Core/Src/bmi270/bmi270_dsd.c ****     /* Array to define the feature configuration */
1917:Core/Src/bmi270/bmi270_dsd.c ****     uint8_t feat_config[BMI2_FEAT_SIZE_IN_BYTES] = { 0 };
1918:Core/Src/bmi270/bmi270_dsd.c **** 
1919:Core/Src/bmi270/bmi270_dsd.c ****     /* Variable to define the array offset */
1920:Core/Src/bmi270/bmi270_dsd.c ****     uint8_t idx = 0;
1921:Core/Src/bmi270/bmi270_dsd.c **** 
1922:Core/Src/bmi270/bmi270_dsd.c ****     /* Variable to set flag */
