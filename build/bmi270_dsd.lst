1842:Core/Src/bmi270/bmi270_dsd.c ****     {
1843:Core/Src/bmi270/bmi270_dsd.c ****         /* Get status of advance power save mode */
1844:Core/Src/bmi270/bmi270_dsd.c ****         aps_stat = dev->aps_status;
