1855:Core/Src/bmi270/bmi270_dsd.c **** 
1856:Core/Src/bmi270/bmi270_dsd.c ****         /* Enable Advance power save if disabled while
1857:Core/Src/bmi270/bmi270_dsd.c ****          * configuring and not when already disabled
1858:Core/Src/bmi270/bmi270_dsd.c ****          */
1859:Core/Src/bmi270/bmi270_dsd.c ****         if ((aps_stat == BMI2_ENABLE) && (rslt == BMI2_OK))
1860:Core/Src/bmi270/bmi270_dsd.c ****         {
1861:Core/Src/bmi270/bmi270_dsd.c ****             rslt = bmi2_set_adv_power_save(BMI2_ENABLE, dev);
1862:Core/Src/bmi270/bmi270_dsd.c ****         }
