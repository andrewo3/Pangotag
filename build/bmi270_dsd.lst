1926:Core/Src/bmi270/bmi270_dsd.c ****     struct bmi2_feature_config any_mot_config = { 0, 0, 0 };
1927:Core/Src/bmi270/bmi270_dsd.c **** 
1928:Core/Src/bmi270/bmi270_dsd.c ****     /* Search for any-motion feature and extract its configurations details */
1929:Core/Src/bmi270/bmi270_dsd.c ****     feat_found = bmi2_extract_input_feat_config(&any_mot_config, BMI2_ANY_MOTION, dev);
1930:Core/Src/bmi270/bmi270_dsd.c ****     if (feat_found)
1931:Core/Src/bmi270/bmi270_dsd.c ****     {
1932:Core/Src/bmi270/bmi270_dsd.c ****         /* Get the configuration from the page where any-motion feature resides */
1933:Core/Src/bmi270/bmi270_dsd.c ****         rslt = bmi2_get_feat_config(any_mot_config.page, feat_config, dev);
1934:Core/Src/bmi270/bmi270_dsd.c ****         if (rslt == BMI2_OK)
1935:Core/Src/bmi270/bmi270_dsd.c ****         {
1936:Core/Src/bmi270/bmi270_dsd.c ****             /* Define the offset for enable/disable of any-motion axes */
1937:Core/Src/bmi270/bmi270_dsd.c ****             idx = any_mot_config.start_addr + BMI2_ANY_MOT_FEAT_EN_OFFSET;
1938:Core/Src/bmi270/bmi270_dsd.c **** 
1939:Core/Src/bmi270/bmi270_dsd.c ****             /* Set the feature enable bit */
1940:Core/Src/bmi270/bmi270_dsd.c ****             feat_config[idx] = BMI2_SET_BITS(feat_config[idx], BMI2_ANY_NO_MOT_EN, enable);
1941:Core/Src/bmi270/bmi270_dsd.c **** 
1942:Core/Src/bmi270/bmi270_dsd.c ****             /* Set the configuration back to the page */
1943:Core/Src/bmi270/bmi270_dsd.c ****             rslt = bmi2_set_regs(BMI2_FEATURES_REG_ADDR, feat_config, BMI2_FEAT_SIZE_IN_BYTES, dev)
1944:Core/Src/bmi270/bmi270_dsd.c **** 
