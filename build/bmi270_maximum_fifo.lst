 128:Core/Src/bmi270/bmi270_maximum_fifo.c ****         dev->variant_feature = BMI2_GYRO_CROSS_SENS_ENABLE | BMI2_MAXIMUM_FIFO_VARIANT;
 129:Core/Src/bmi270/bmi270_maximum_fifo.c **** 
