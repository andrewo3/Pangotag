 119:Core/Src/bmi270/bmi270_maximum_fifo.c **** 
 120:Core/Src/bmi270/bmi270_maximum_fifo.c ****     if (rslt == BMI2_OK)
 121:Core/Src/bmi270/bmi270_maximum_fifo.c ****     {
 122:Core/Src/bmi270/bmi270_maximum_fifo.c ****         /* Assign chip id of BMI270 */
 123:Core/Src/bmi270/bmi270_maximum_fifo.c ****         dev->chip_id = BMI270_MAXIMUM_FIFO_CHIP_ID;
