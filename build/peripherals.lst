 541:Core/Src/peripherals.c **** 
 542:Core/Src/peripherals.c ****     // Restore PA9 to USART1_RX alternate-function mode before re-enabling
 543:Core/Src/peripherals.c ****     // the USART1 IRQ. HAL_UART_MspInit() above should already do this if
 544:Core/Src/peripherals.c ****     // it's the CubeMX-generated version — but set it explicitly so we're
