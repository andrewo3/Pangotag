 503:Core/Src/peripherals.c **** void tag_sleep() {
 504:Core/Src/peripherals.c ****     printf("starting sleep process...\n");
 505:Core/Src/peripherals.c ****     setupAccSleep();
 506:Core/Src/peripherals.c **** 
 507:Core/Src/peripherals.c ****     uint8_t sleep = 0;
 508:Core/Src/peripherals.c **** 
 509:Core/Src/peripherals.c ****     // Put PA9 (USART1_TX) into high-Z so it doesn't source/sink current
 510:Core/Src/peripherals.c ****     // or float into the UART peripheral while we're powered down.
 511:Core/Src/peripherals.c **** 
 512:Core/Src/peripherals.c ****     packet sleepPack = {0};
 513:Core/Src/peripherals.c ****     sleepPack.type = PACKET_WAKE;
 514:Core/Src/peripherals.c ****     sleepPack.timestamp = HAL_GetTick() - startTime;
 515:Core/Src/peripherals.c ****     sleepPack.rtcTimestamp = rtcElapsed();
 516:Core/Src/peripherals.c ****     sleepPack.len = 1;
 517:Core/Src/peripherals.c ****     sleepPack.payload = &sleep;
 518:Core/Src/peripherals.c ****     writePacket(sleepPack);
 519:Core/Src/peripherals.c **** 
 520:Core/Src/peripherals.c ****     // Don't disarm the FIFO accel's wake-capable EXTI while it's unpowered
 521:Core/Src/peripherals.c ****     HAL_NVIC_DisableIRQ(EXTI1_IRQn);
 522:Core/Src/peripherals.c ****     printf("sleeping...\n");
 523:Core/Src/peripherals.c ****     sensors_off();
 524:Core/Src/peripherals.c **** 
 525:Core/Src/peripherals.c ****     // Arm the wake source and enter STOP2 atomically, right next to each other
 526:Core/Src/peripherals.c ****     __disable_irq();
 527:Core/Src/peripherals.c ****     __HAL_GPIO_EXTI_CLEAR_IT(Acc_Int_Pin);
 528:Core/Src/peripherals.c ****     HAL_SuspendTick();
 529:Core/Src/peripherals.c ****     __enable_irq();                 // pending-IRQ check at WFI still wakes correctly
 530:Core/Src/peripherals.c ****     HAL_PWREx_EnterSTOP2Mode(PWR_STOPENTRY_WFI);
 531:Core/Src/peripherals.c ****     // resumes here on wake
 532:Core/Src/peripherals.c ****     HAL_ResumeTick();
 533:Core/Src/peripherals.c ****     sensors_on();
 534:Core/Src/peripherals.c **** 
 535:Core/Src/peripherals.c ****     SystemClock_Config();
 536:Core/Src/peripherals.c ****     HAL_I2C_MspInit(&hi2c1);
 537:Core/Src/peripherals.c ****     HAL_I2C_MspInit(&hi2c2);
