  73:Core/Inc/datetime.h **** 
  74:Core/Inc/datetime.h ****     /* Determine year */
  75:Core/Inc/datetime.h ****     while (1)
  76:Core/Inc/datetime.h ****     {
  77:Core/Inc/datetime.h ****         uint32_t year_seconds =
  78:Core/Inc/datetime.h ****             (uint32_t)(is_leap_year(year) ? 366 : 365) * 86400ULL;
  79:Core/Inc/datetime.h **** 
  80:Core/Inc/datetime.h ****         if (epoch < year_seconds)
  81:Core/Inc/datetime.h ****             break;
  82:Core/Inc/datetime.h **** 
  83:Core/Inc/datetime.h ****         epoch -= year_seconds;
  84:Core/Inc/datetime.h ****         year++;
  85:Core/Inc/datetime.h ****     }
  86:Core/Inc/datetime.h **** 
  87:Core/Inc/datetime.h ****     dt.da.Year = year - EPOCH_YEAR;
  88:Core/Inc/datetime.h **** 
  89:Core/Inc/datetime.h ****     /* Determine month */
  90:Core/Inc/datetime.h ****     int month = 1;
  91:Core/Inc/datetime.h **** 
