1243:Core/Src/bmi270/bmi270_legacy.c **** /*!
1244:Core/Src/bmi270/bmi270_legacy.c ****  * @brief This internal API sets flat configurations like theta, blocking,
1245:Core/Src/bmi270/bmi270_legacy.c ****  * hold-time, hysteresis, and output configuration.
1246:Core/Src/bmi270/bmi270_legacy.c ****  *
1247:Core/Src/bmi270/bmi270_legacy.c ****  * @param[in]      config         : Structure instance of bmi2_flat_config.
1248:Core/Src/bmi270/bmi270_legacy.c ****  * @param[in, out] dev            : Structure instance of bmi2_dev.
1249:Core/Src/bmi270/bmi270_legacy.c ****  *
1250:Core/Src/bmi270/bmi270_legacy.c ****  * @verbatim
1251:Core/Src/bmi270/bmi270_legacy.c ****  *----------------------------------------------------------------------------
1252:Core/Src/bmi270/bmi270_legacy.c ****  *      bmi2_flat_config    |
1253:Core/Src/bmi270/bmi270_legacy.c ****  *      Structure parameters|               Description
1254:Core/Src/bmi270/bmi270_legacy.c ****  *--------------------------|--------------------------------------------------
1255:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Sets the theta angle, used for detecting flat
1256:Core/Src/bmi270/bmi270_legacy.c ****  *                          | position.
1257:Core/Src/bmi270/bmi270_legacy.c ****  *      theta               | Theta = 64 * (tan(angle)^2);
1258:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Default value is 8, equivalent to 20 degrees angle
1259:Core/Src/bmi270/bmi270_legacy.c ****  * -------------------------|---------------------------------------------------
1260:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Hysteresis for Theta Flat detection.
1261:Core/Src/bmi270/bmi270_legacy.c ****  *      hysteresis          | Default value is 9 = 2.5 degrees, corresponding
1262:Core/Src/bmi270/bmi270_legacy.c ****  *                          | to the default Theta angle of 20 degrees.
1263:Core/Src/bmi270/bmi270_legacy.c ****  * -------------------------|---------------------------------------------------
1264:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Sets the blocking mode. If blocking is set, no
1265:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Flat interrupt will be triggered.
1266:Core/Src/bmi270/bmi270_legacy.c ****  *      blocking            | Default value is 2, the most restrictive blocking
1267:Core/Src/bmi270/bmi270_legacy.c ****  *                          | mode.
1268:Core/Src/bmi270/bmi270_legacy.c ****  * -------------------------|---------------------------------------------------
1269:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Holds the duration in 50Hz samples for which the
1270:Core/Src/bmi270/bmi270_legacy.c ****  *                          | condition has to be respected.
1271:Core/Src/bmi270/bmi270_legacy.c ****  *      hold-time           | Default value is 32 = 640 msec.
1272:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Range is 0 to 5.1 sec.
1273:Core/Src/bmi270/bmi270_legacy.c ****  * -------------------------|---------------------------------------------------
1274:Core/Src/bmi270/bmi270_legacy.c ****  * @endverbatim
1275:Core/Src/bmi270/bmi270_legacy.c ****  *
1276:Core/Src/bmi270/bmi270_legacy.c ****  * @return Result of API execution status
1277:Core/Src/bmi270/bmi270_legacy.c ****  * @retval 0 -> Success
1278:Core/Src/bmi270/bmi270_legacy.c ****  * @retval < 0 -> Fail
1279:Core/Src/bmi270/bmi270_legacy.c ****  */
1280:Core/Src/bmi270/bmi270_legacy.c **** static int8_t set_flat_config(const struct bmi2_flat_config *config, struct bmi2_dev *dev);
