1838:Core/Src/bmi270/bmi270_legacy.c **** 
1839:Core/Src/bmi270/bmi270_legacy.c ****         /* Get the size of config array */
1840:Core/Src/bmi270/bmi270_legacy.c ****         dev->config_size = sizeof(bmi270_legacy_config_file);
1841:Core/Src/bmi270/bmi270_legacy.c **** 
1842:Core/Src/bmi270/bmi270_legacy.c ****         /* Enable the variant specific features if any */
1843:Core/Src/bmi270/bmi270_legacy.c ****         dev->variant_feature = BMI2_CRT_RTOSK_ENABLE | BMI2_GYRO_CROSS_SENS_ENABLE;
1844:Core/Src/bmi270/bmi270_legacy.c **** 
1845:Core/Src/bmi270/bmi270_legacy.c ****         /* An extra dummy byte is read during SPI read */
