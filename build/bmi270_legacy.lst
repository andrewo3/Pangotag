1411:Core/Src/bmi270/bmi270_legacy.c **** /*!
1412:Core/Src/bmi270/bmi270_legacy.c ****  * @brief This internal API gets orientation configurations like upside/down
1413:Core/Src/bmi270/bmi270_legacy.c ****  * detection, symmetrical modes, blocking mode, theta, hysteresis and output
1414:Core/Src/bmi270/bmi270_legacy.c ****  * configuration.
1415:Core/Src/bmi270/bmi270_legacy.c ****  *
1416:Core/Src/bmi270/bmi270_legacy.c ****  * @param[out]     config         : Structure instance of bmi2_orient_config.
1417:Core/Src/bmi270/bmi270_legacy.c ****  * @param[in, out] dev            : Structure instance of bmi2_dev.
1418:Core/Src/bmi270/bmi270_legacy.c ****  *
1419:Core/Src/bmi270/bmi270_legacy.c ****  * @verbatim
1420:Core/Src/bmi270/bmi270_legacy.c ****  *-----------------------------------------------------------------------------
1421:Core/Src/bmi270/bmi270_legacy.c ****  *    bmi2_orient_config    |
1422:Core/Src/bmi270/bmi270_legacy.c ****  *   Structure parameters   |               Description
1423:Core/Src/bmi270/bmi270_legacy.c ****  *--------------------------|--------------------------------------------------
1424:Core/Src/bmi270/bmi270_legacy.c ****  *  upside/down             |  Enables upside/down detection, if set to 1.
1425:Core/Src/bmi270/bmi270_legacy.c ****  *  detection               |
1426:Core/Src/bmi270/bmi270_legacy.c ****  * -------------------------|---------------------------------------------------
1427:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Sets the mode:
1428:Core/Src/bmi270/bmi270_legacy.c ****  *      mode                | Values 0 or 3 - symmetrical.
1429:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Value 1       - high asymmetrical
1430:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Value 2       - low asymmetrical
1431:Core/Src/bmi270/bmi270_legacy.c ****  * -------------------------|---------------------------------------------------
1432:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Enable - no orientation interrupt will be set.
1433:Core/Src/bmi270/bmi270_legacy.c ****  *      blocking            | Default value: 3, the most restrictive blocking.
1434:Core/Src/bmi270/bmi270_legacy.c ****  * -------------------------|---------------------------------------------------
1435:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Threshold angle used in blocking mode.
1436:Core/Src/bmi270/bmi270_legacy.c ****  *      theta               | Theta = 64 * (tan(angle)^2)
1437:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Default value: 40, equivalent to 38 degrees angle.
1438:Core/Src/bmi270/bmi270_legacy.c ****  * -------------------------|---------------------------------------------------
1439:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Acceleration hysteresis for Orientation detection
1440:Core/Src/bmi270/bmi270_legacy.c ****  *                          | is expressed in 5.11g format.
1441:Core/Src/bmi270/bmi270_legacy.c ****  *      hysteresis          | Default value is 128 = 0.0625g.
1442:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Range is 0 to 1g.
1443:Core/Src/bmi270/bmi270_legacy.c ****  * -------------------------|---------------------------------------------------
1444:Core/Src/bmi270/bmi270_legacy.c ****  * @endverbatim
1445:Core/Src/bmi270/bmi270_legacy.c ****  *
1446:Core/Src/bmi270/bmi270_legacy.c ****  * @return Result of API execution status
1447:Core/Src/bmi270/bmi270_legacy.c ****  * @retval 0 -> Success
1448:Core/Src/bmi270/bmi270_legacy.c ****  * @retval < 0 -> Fail
1449:Core/Src/bmi270/bmi270_legacy.c ****  */
1450:Core/Src/bmi270/bmi270_legacy.c **** static int8_t get_orient_config(struct bmi2_orient_config *config, struct bmi2_dev *dev);
1451:Core/Src/bmi270/bmi270_legacy.c **** 
1452:Core/Src/bmi270/bmi270_legacy.c **** /*!
1453:Core/Src/bmi270/bmi270_legacy.c ****  * @brief This internal API gets high-g configurations like threshold,
1454:Core/Src/bmi270/bmi270_legacy.c ****  * hysteresis, duration, and output configuration.
1455:Core/Src/bmi270/bmi270_legacy.c ****  *
ARM GAS  /var/folders/gv/t2w3mcd17yl2fynvjl120d0m0000gn/T//ccDW1WpJ.s 			page 27


1456:Core/Src/bmi270/bmi270_legacy.c ****  * @param[out]     config         : Structure instance of bmi2_high_g_config.
1457:Core/Src/bmi270/bmi270_legacy.c ****  * @param[in, out] dev            : Structure instance of bmi2_dev.
1458:Core/Src/bmi270/bmi270_legacy.c ****  *
1459:Core/Src/bmi270/bmi270_legacy.c ****  * @verbatim
1460:Core/Src/bmi270/bmi270_legacy.c ****  *-----------------------------------------------------------------------------
1461:Core/Src/bmi270/bmi270_legacy.c ****  *      bmi2_high_g_config  |
1462:Core/Src/bmi270/bmi270_legacy.c ****  *      Structure parameter |               Description
1463:Core/Src/bmi270/bmi270_legacy.c ****  *--------------------------|--------------------------------------------------
1464:Core/Src/bmi270/bmi270_legacy.c ****  *      threshold           |  The acceleration threshold above which the
1465:Core/Src/bmi270/bmi270_legacy.c ****  *                          |  high_g motion is signaled.
1466:Core/Src/bmi270/bmi270_legacy.c ****  *                          |  Holds threshold in 5.11 g format.
1467:Core/Src/bmi270/bmi270_legacy.c ****  *                          |  Default is 3072 = 1.5 g.
1468:Core/Src/bmi270/bmi270_legacy.c ****  *                          |  Range is 0 to 16g.
1469:Core/Src/bmi270/bmi270_legacy.c ****  * -------------------------|---------------------------------------------------
1470:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Acceleration hysteresis for high-g detection
1471:Core/Src/bmi270/bmi270_legacy.c ****  *                          | is expressed in 1.11g format.
1472:Core/Src/bmi270/bmi270_legacy.c ****  *      hysteresis          | Default value is 256 = 0.125 g.
1473:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Range is 0 to 2g.
1474:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Should be smaller than threshold.
1475:Core/Src/bmi270/bmi270_legacy.c ****  * -------------------------|---------------------------------------------------
1476:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Holds the duration in 200 Hz samples (5 ms) for
1477:Core/Src/bmi270/bmi270_legacy.c ****  *                          | which the threshold has to be exceeded.
1478:Core/Src/bmi270/bmi270_legacy.c ****  *      duration            |Default value 4 = 20 msec.
1479:Core/Src/bmi270/bmi270_legacy.c ****  *                          | Range is 0 to 20sec.
1480:Core/Src/bmi270/bmi270_legacy.c ****  * -------------------------|---------------------------------------------------
1481:Core/Src/bmi270/bmi270_legacy.c ****  *  select_x, select_y,     |
1482:Core/Src/bmi270/bmi270_legacy.c ****  *       select_z           |  Selects the feature on a per-axis basis
1483:Core/Src/bmi270/bmi270_legacy.c ****  * -------------------------|---------------------------------------------------
1484:Core/Src/bmi270/bmi270_legacy.c ****  * @endverbatim
1485:Core/Src/bmi270/bmi270_legacy.c ****  *
1486:Core/Src/bmi270/bmi270_legacy.c ****  * @return Result of API execution status
1487:Core/Src/bmi270/bmi270_legacy.c ****  * @retval 0 -> Success
1488:Core/Src/bmi270/bmi270_legacy.c ****  * @retval < 0 -> Fail
1489:Core/Src/bmi270/bmi270_legacy.c ****  */
1490:Core/Src/bmi270/bmi270_legacy.c **** static int8_t get_high_g_config(struct bmi2_high_g_config *config, struct bmi2_dev *dev);
1491:Core/Src/bmi270/bmi270_legacy.c **** 
1492:Core/Src/bmi270/bmi270_legacy.c **** /*!
1493:Core/Src/bmi270/bmi270_legacy.c ****  * @brief This internal API gets low-g configurations like threshold,
1494:Core/Src/bmi270/bmi270_legacy.c ****  * hysteresis, duration, and output configuration.
1495:Core/Src/bmi270/bmi270_legacy.c ****  *
1496:Core/Src/bmi270/bmi270_legacy.c ****  * @param[out]     config     : Structure instance of bmi2_low_g_config.
