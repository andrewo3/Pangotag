1833:Core/Src/bmi270/bmi270_legacy.c ****     rslt = null_ptr_check(dev);
1834:Core/Src/bmi270/bmi270_legacy.c ****     if (rslt == BMI2_OK)
1835:Core/Src/bmi270/bmi270_legacy.c ****     {
1836:Core/Src/bmi270/bmi270_legacy.c ****         /* Assign chip id of BMI270_LEGACY */
