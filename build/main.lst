 302:Core/Src/main.c ****         printf("Successful fifo frame read: %i frames\n",fifo.length);
 303:Core/Src/main.c ****         bmi2_get_fifo_length(&fifo_len, &dev);
 304:Core/Src/main.c ****         printf("fifo length after = %u\n", fifo_len);
 305:Core/Src/main.c **** 
 306:Core/Src/main.c ****         struct bmi2_sens_axes_data accel_data[128];
 307:Core/Src/main.c ****         struct bmi2_sens_axes_data gyro_data[128];
 308:Core/Src/main.c **** 
 309:Core/Src/main.c ****         uint16_t acc_frames = 128;
 310:Core/Src/main.c ****         uint16_t gyr_frames = 128;
 311:Core/Src/main.c **** 
 312:Core/Src/main.c ****         rslt = bmi2_extract_accel(accel_data, &acc_frames, &fifo, &dev);
 313:Core/Src/main.c ****         if (rslt < BMI2_OK) {
 314:Core/Src/main.c ****           printf("Failed to extract acceleration frame: err %i\n",rslt);
 315:Core/Src/main.c ****         }
 316:Core/Src/main.c ****         rslt = bmi2_extract_gyro(gyro_data, &gyr_frames, &fifo, &dev);
 317:Core/Src/main.c ****         if (rslt < BMI2_OK) {
 318:Core/Src/main.c ****           printf("Failed to extract gyroscope frame: err %i\n",rslt);
 319:Core/Src/main.c ****         }
 320:Core/Src/main.c ****         printf("Frame 1: (%i,%i,%i) @ time %i\n",accel_data[0].x,accel_data[0].y,accel_data[0].z,ac
 321:Core/Src/main.c **** 
 322:Core/Src/main.c ****         printf("Decoded %i acc frames and %i gyro frames.\n",acc_frames, gyr_frames);
 323:Core/Src/main.c **** 
 324:Core/Src/main.c ****         bmi2_get_int_status(&int_status, &dev);
 325:Core/Src/main.c ****         printf("FIFO Status: %i\n",int_status);
 326:Core/Src/main.c ****       }
 327:Core/Src/main.c ****     }
 328:Core/Src/main.c ****     update_LED(HAL_GetTick() - start, 1000);
 329:Core/Src/main.c ****   }
