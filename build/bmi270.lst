2038:Core/Src/bmi270/bmi270.c **** 
2039:Core/Src/bmi270/bmi270.c ****         if (rslt == BMI2_OK)
2040:Core/Src/bmi270/bmi270.c ****         {
2041:Core/Src/bmi270/bmi270.c ****             rslt = enable_sensor_features(sensor_sel, dev);
2042:Core/Src/bmi270/bmi270.c **** 
2043:Core/Src/bmi270/bmi270.c ****             /* Enable Advance power save if disabled while
2044:Core/Src/bmi270/bmi270.c ****              * configuring and not when already disabled
2045:Core/Src/bmi270/bmi270.c ****              */
2046:Core/Src/bmi270/bmi270.c ****             if ((aps_stat == BMI2_ENABLE) && (rslt == BMI2_OK))
2047:Core/Src/bmi270/bmi270.c ****             {
2048:Core/Src/bmi270/bmi270.c ****                 rslt = bmi2_set_adv_power_save(BMI2_ENABLE, dev);
2049:Core/Src/bmi270/bmi270.c ****             }
2050:Core/Src/bmi270/bmi270.c ****         }
2051:Core/Src/bmi270/bmi270.c ****     }
2052:Core/Src/bmi270/bmi270.c **** 
