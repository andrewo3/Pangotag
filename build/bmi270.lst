1525:Core/Src/bmi270/bmi270.c ****             {
1526:Core/Src/bmi270/bmi270.c ****                 rslt = bmi2_set_sensor_config(&sens_cfg[loop], 1, dev);
1527:Core/Src/bmi270/bmi270.c ****             }
1528:Core/Src/bmi270/bmi270.c ****             else
1529:Core/Src/bmi270/bmi270.c ****             {
