1517:Core/Src/bmi270/bmi270.c ****     {
1518:Core/Src/bmi270/bmi270.c ****         /* Get status of advance power save mode */
1519:Core/Src/bmi270/bmi270.c ****         aps_stat = dev->aps_status;
