1368:Core/Src/bmi270/bmi270.c **** 
1369:Core/Src/bmi270/bmi270.c ****         /* Enable the variant specific features if any */
1370:Core/Src/bmi270/bmi270.c ****         dev->variant_feature = BMI2_GYRO_CROSS_SENS_ENABLE | BMI2_CRT_RTOSK_ENABLE;
1371:Core/Src/bmi270/bmi270.c **** 
1372:Core/Src/bmi270/bmi270.c ****         /* An extra dummy byte is read during SPI read */
1373:Core/Src/bmi270/bmi270.c ****         if (dev->intf == BMI2_SPI_INTF)
1374:Core/Src/bmi270/bmi270.c ****         {
1375:Core/Src/bmi270/bmi270.c ****             dev->dummy_byte = 1;
1376:Core/Src/bmi270/bmi270.c ****         }
1377:Core/Src/bmi270/bmi270.c ****         else
1378:Core/Src/bmi270/bmi270.c ****         {
1379:Core/Src/bmi270/bmi270.c ****             dev->dummy_byte = 0;
1380:Core/Src/bmi270/bmi270.c ****         }
1381:Core/Src/bmi270/bmi270.c **** 
1382:Core/Src/bmi270/bmi270.c ****         /* If configuration file pointer is not assigned any address */
1383:Core/Src/bmi270/bmi270.c ****         if (!dev->config_file_ptr)
1384:Core/Src/bmi270/bmi270.c ****         {
1385:Core/Src/bmi270/bmi270.c ****             /* Give the address of the configuration file array to
1386:Core/Src/bmi270/bmi270.c ****              * the device pointer
1387:Core/Src/bmi270/bmi270.c ****              */
1388:Core/Src/bmi270/bmi270.c ****             dev->config_file_ptr = bmi270_config_file;
1389:Core/Src/bmi270/bmi270.c ****         }
1390:Core/Src/bmi270/bmi270.c **** 
1391:Core/Src/bmi270/bmi270.c ****         /* Initialize BMI2 sensor */
1392:Core/Src/bmi270/bmi270.c ****         rslt = bmi2_sec_init(dev);
1393:Core/Src/bmi270/bmi270.c ****         if (rslt == BMI2_OK)
1394:Core/Src/bmi270/bmi270.c ****         {
1395:Core/Src/bmi270/bmi270.c ****             /* Assign the offsets of the feature input
1396:Core/Src/bmi270/bmi270.c ****              * configuration to the device structure
1397:Core/Src/bmi270/bmi270.c ****              */
1398:Core/Src/bmi270/bmi270.c ****             dev->feat_config = bmi270_feat_in;
