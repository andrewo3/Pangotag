1359:Core/Src/bmi270/bmi270.c ****     /* Null-pointer check */
1360:Core/Src/bmi270/bmi270.c ****     rslt = null_ptr_check(dev);
1361:Core/Src/bmi270/bmi270.c ****     if (rslt == BMI2_OK)
