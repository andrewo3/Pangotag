2096:Core/Src/bmi270/bmi270.c **** /*!
2097:Core/Src/bmi270/bmi270.c ****  * @brief This internal API is used to enable/disable any motion feature.
2098:Core/Src/bmi270/bmi270.c ****  */
2099:Core/Src/bmi270/bmi270.c **** static int8_t set_any_motion(uint8_t enable, struct bmi2_dev *dev)
2100:Core/Src/bmi270/bmi270.c **** {
2101:Core/Src/bmi270/bmi270.c ****     /* Variable to define error */
2102:Core/Src/bmi270/bmi270.c ****     int8_t rslt;
2103:Core/Src/bmi270/bmi270.c **** 
2104:Core/Src/bmi270/bmi270.c ****     /* Array to define the feature configuration */
2105:Core/Src/bmi270/bmi270.c ****     uint8_t feat_config[BMI2_FEAT_SIZE_IN_BYTES] = { 0 };
2106:Core/Src/bmi270/bmi270.c **** 
2107:Core/Src/bmi270/bmi270.c ****     /* Variable to define the array offset */
2108:Core/Src/bmi270/bmi270.c ****     uint8_t idx = 0;
2109:Core/Src/bmi270/bmi270.c **** 
2110:Core/Src/bmi270/bmi270.c ****     /* Variable to set flag */
2111:Core/Src/bmi270/bmi270.c ****     uint8_t feat_found;
2112:Core/Src/bmi270/bmi270.c **** 
2113:Core/Src/bmi270/bmi270.c ****     /* Initialize feature configuration for any-motion */
2114:Core/Src/bmi270/bmi270.c ****     struct bmi2_feature_config any_mot_config = { 0, 0, 0 };
2115:Core/Src/bmi270/bmi270.c **** 
2116:Core/Src/bmi270/bmi270.c ****     /* Search for any-motion feature and extract its configurations details */
2117:Core/Src/bmi270/bmi270.c ****     feat_found = bmi2_extract_input_feat_config(&any_mot_config, BMI2_ANY_MOTION, dev);
2118:Core/Src/bmi270/bmi270.c ****     if (feat_found)
2119:Core/Src/bmi270/bmi270.c ****     {
2120:Core/Src/bmi270/bmi270.c ****         /* Get the configuration from the page where any-motion feature resides */
2121:Core/Src/bmi270/bmi270.c ****         rslt = bmi2_get_feat_config(any_mot_config.page, feat_config, dev);
2122:Core/Src/bmi270/bmi270.c ****         if (rslt == BMI2_OK)
2123:Core/Src/bmi270/bmi270.c ****         {
2124:Core/Src/bmi270/bmi270.c ****             /* Define the offset for enable/disable of any-motion axes */
2125:Core/Src/bmi270/bmi270.c ****             idx = any_mot_config.start_addr + BMI2_ANY_MOT_FEAT_EN_OFFSET;
2126:Core/Src/bmi270/bmi270.c **** 
2127:Core/Src/bmi270/bmi270.c ****             /* Set the feature enable bit */
2128:Core/Src/bmi270/bmi270.c ****             feat_config[idx] = BMI2_SET_BITS(feat_config[idx], BMI2_ANY_NO_MOT_EN, enable);
2129:Core/Src/bmi270/bmi270.c **** 
2130:Core/Src/bmi270/bmi270.c ****             /* Set the configuration back to the page */
2131:Core/Src/bmi270/bmi270.c ****             rslt = bmi2_set_regs(BMI2_FEATURES_REG_ADDR, feat_config, BMI2_FEAT_SIZE_IN_BYTES, dev)
2132:Core/Src/bmi270/bmi270.c **** 
2133:Core/Src/bmi270/bmi270.c ****             if ((rslt == BMI2_OK) && (enable == BMI2_ENABLE))
2134:Core/Src/bmi270/bmi270.c ****             {
2135:Core/Src/bmi270/bmi270.c ****                 dev->sens_en_stat |= BMI2_ANY_MOT_SEL;
2136:Core/Src/bmi270/bmi270.c ****             }
2137:Core/Src/bmi270/bmi270.c ****             else
2138:Core/Src/bmi270/bmi270.c ****             {
2139:Core/Src/bmi270/bmi270.c ****                 dev->sens_en_stat &= ~BMI2_ANY_MOT_SEL;
2140:Core/Src/bmi270/bmi270.c ****             }
2141:Core/Src/bmi270/bmi270.c ****         }
2142:Core/Src/bmi270/bmi270.c ****     }
2143:Core/Src/bmi270/bmi270.c ****     else
2144:Core/Src/bmi270/bmi270.c ****     {
2145:Core/Src/bmi270/bmi270.c ****         rslt = BMI2_E_INVALID_SENSOR;
2146:Core/Src/bmi270/bmi270.c ****     }
2147:Core/Src/bmi270/bmi270.c **** 
2148:Core/Src/bmi270/bmi270.c ****     return rslt;
2149:Core/Src/bmi270/bmi270.c **** }
