2020:Core/Src/bmi270/bmi270.c **** {
2021:Core/Src/bmi270/bmi270.c ****     /* Variable to define error */
2022:Core/Src/bmi270/bmi270.c ****     int8_t rslt;
2023:Core/Src/bmi270/bmi270.c **** 
2024:Core/Src/bmi270/bmi270.c ****     /* Variable to get the status of advance power save */
